<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<%
  var ff = typeof fontFamily !== 'undefined' ? fontFamily : 'Cairo';
  var cfu = typeof customFontUrl !== 'undefined' ? customFontUrl : '';
  var defaultFonts = ['Cairo', 'Tajawal', 'Amiri', 'Roboto', 'Poppins', 'Open Sans', 'Noto Sans Arabic'];
%>
<% if (cfu) { %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="<%= cfu %>" rel="stylesheet">
<% } else if (defaultFonts.indexOf(ff) !== -1 && ff !== 'Arial') { %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=<%= encodeURIComponent(ff) %>:wght@300;400;600;700;800&display=swap" rel="stylesheet">
<% } %>
<%
  var pc = typeof primaryColor !== 'undefined' ? primaryColor : '#000000';
  var sc = typeof secondaryColor !== 'undefined' ? secondaryColor : '#333333';
  var btnc = typeof buttonColor !== 'undefined' ? buttonColor : '#000000';
  var btntc = typeof buttonTextColor !== 'undefined' ? buttonTextColor : '#FFFFFF';
  var tc = typeof textColor !== 'undefined' ? textColor : '#000000';
  var bgc = typeof bgColor !== 'undefined' ? bgColor : '#FFFFFF';
  var hbgc = typeof headerBgColor !== 'undefined' ? headerBgColor : '#FFFFFF';
  var htc = typeof headerTextColor !== 'undefined' ? headerTextColor : '#000000';
  var fbgc = typeof footerBgColor !== 'undefined' ? footerBgColor : '#1a1a1a';
  var ftc = typeof footerTextColor !== 'undefined' ? footerTextColor : '#FFFFFF';
  var brc = typeof borderColor !== 'undefined' ? borderColor : '#000000';
  var sac = typeof sliderArrowColor !== 'undefined' ? sliderArrowColor : '#333333';
  var sabgc = typeof sliderArrowBgColor !== 'undefined' ? sliderArrowBgColor : 'rgba(255,255,255,0.9)';
%>
<link rel="stylesheet" href="/css/style.css">
<style>
:root {
  --font-body: '<%= ff %>', 'Segoe UI', sans-serif;
  --color-primary: <%= pc %>;
  --color-primary-dark: <%= sc %>;
  --color-secondary: <%= sc %>;
  --color-button: <%= btnc %>;
  --color-button-text: <%= btntc %>;
  --color-text: <%= tc %>;
  --color-bg: <%= bgc %>;
  --color-bg-warm: <%= bgc %>;
  --color-header-bg: <%= hbgc %>;
  --color-header-text: <%= htc %>;
  --color-footer-bg: <%= fbgc %>;
  --color-footer-text: <%= ftc %>;
  --color-border: <%= brc %>;
  --color-slider-arrow: <%= sac %>;
  --color-slider-arrow-bg: <%= sabgc %>;
}
/* Dynamic theme overrides */
body { background-color: var(--color-bg); color: var(--color-text); }
.navbar { background: var(--color-header-bg) !important; }
.navbar.scrolled { background: var(--color-header-bg) !important; }
.navbar, .navbar a, .navbar__name, .navbar button { color: var(--color-header-text) !important; }
.navbar__logo { background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark)); }
.footer { background: var(--color-footer-bg) !important; color: var(--color-footer-text) !important; }
.footer a { color: var(--color-footer-text) !important; opacity: 0.8; }
.btn--primary { background: linear-gradient(135deg, var(--color-button), var(--color-button)) !important; color: var(--color-button-text) !important; box-shadow: none; }
.btn--primary:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.15); }
.cta-section { background: linear-gradient(135deg, var(--color-primary-dark), var(--color-primary)); }
.cta-section .btn--primary { background: var(--color-button-text) !important; color: var(--color-button) !important; }
.section-header__divider { background: linear-gradient(90deg, var(--color-primary), var(--color-primary-dark)); }
.hero__price-current { color: var(--color-primary); }
.collection-viewall { color: var(--color-primary); }
</style>

<%/* SEO Meta Tags */%>
<% if (typeof metaDescription !== 'undefined' && metaDescription) { %>
  <meta name="description" content="<%= metaDescription %>">
<% } %>

<%/* OG Tags for Social Sharing */%>
<% if (typeof metaTitle !== 'undefined' && metaTitle) { %>
  <meta property="og:title" content="<%= metaTitle %>">
<% } %>
<% if (typeof metaDescription !== 'undefined' && metaDescription) { %>
  <meta property="og:description" content="<%= metaDescription %>">
<% } %>
<% if (typeof ogImage !== 'undefined' && ogImage) { %>
  <meta property="og:image" content="/uploads/settings/<%= ogImage %>">
<% } %>
<meta property="og:type" content="website">

<%/* Favicon */%>
<% if (typeof favicon !== 'undefined' && favicon) { %>
  <link rel="icon" type="image/png" href="/uploads/settings/<%= favicon %>">
<% } else { %>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🛍️</text></svg>">
<% } %>

<%/* Google Analytics */%>
<% if (typeof gaId !== 'undefined' && gaId) { %>
  <script async src="https://www.googletagmanager.com/gtag/js?id=<%= gaId %>"></script>
  <script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','<%= gaId %>');</script>
<% } %>

<%/* Facebook / Meta Pixel */%>
<% if (typeof fbPixelId !== 'undefined' && fbPixelId) { %>
  <script>!function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');fbq('init','<%= fbPixelId %>');fbq('track','PageView');</script>
  <noscript><img height="1" width="1" style="display:none" src="https://www.facebook.com/tr?id=<%= fbPixelId %>&ev=PageView&noscript=1"/></noscript>
<% } %>

<%/* TikTok Pixel */%>
<% if (typeof tiktokPixelId !== 'undefined' && tiktokPixelId) { %>
  <script>!function(w,d,t){w.TiktokAnalyticsObject=t;var ttq=w[t]=w[t]||[];ttq.methods=["page","track","identify","instances","debug","on","off","once","ready","alias","group","enableCookie","disableCookie","holdConsent","revokeConsent","grantConsent"],ttq.setAndDefer=function(t,e){t[e]=function(){t.push([e].concat(Array.prototype.slice.call(arguments,0)))}};for(var i=0;i<ttq.methods.length;i++)ttq.setAndDefer(ttq,ttq.methods[i]);ttq.instance=function(t){for(var e=ttq._i[t]||[],n=0;n<ttq.methods.length;n++)ttq.setAndDefer(e,ttq.methods[n]);return e},ttq.load=function(e,n){var r="https://analytics.tiktok.com/i18n/pixel/events.js",o=n&&n.partner;ttq._i=ttq._i||{},ttq._i[e]=[],ttq._t=ttq._t||{},ttq._t[e]=+new Date,ttq._o=ttq._o||{},ttq._o[e]=n||{};var a=d.createElement("script");a.type="text/javascript",a.async=!0,a.src=r+"?sdkid="+e+"&lib="+t;var s=d.getElementsByTagName("script")[0];s.parentNode.insertBefore(a,s)};ttq.load('<%= tiktokPixelId %>');ttq.page();}(window,document,'ttq');</script>
<% } %>

<%/* Custom Meta/Script Tags */%>
<% if (typeof customMetaTags !== 'undefined' && customMetaTags) { %>
  <%- customMetaTags %>
<% } %>

<%/* Announcement bar layout pre-allocation (prevents flash on Turbo navigation) */%>
<% if (typeof announcementEnabled !== 'undefined' && announcementEnabled) { %>
<% var _preAnnH = typeof announcementHeight !== 'undefined' ? announcementHeight : '44'; %>
<% var _preAnnMH = typeof announcementMobileHeight !== 'undefined' ? announcementMobileHeight : '40'; %>
<style id="ann-bar-css">
  body { padding-top: <%= _preAnnH %>px; }
  .navbar { top: <%= _preAnnH %>px !important; }
  @media (max-width: 768px) {
    body { padding-top: <%= _preAnnMH %>px; }
    .navbar { top: <%= _preAnnMH %>px !important; }
  }
</style>
<% } %>

<%/* Turbo Drive — SPA-like navigation without page reloads */%>
<script>
  // Turbo SPA compat: make DOMContentLoaded handlers re-fire on Turbo navigations.
  // After initial load, DOMContentLoaded never fires again. This patch detects when
  // new body scripts add DOMContentLoaded handlers (after Turbo replaces the body)
  // and runs them immediately since the DOM is already ready.
  (function() {
    var domReady = false;
    var origAdd = EventTarget.prototype.addEventListener;
    origAdd.call(document, 'DOMContentLoaded', function() { domReady = true; });
    EventTarget.prototype.addEventListener = function(type, fn, opts) {
      if (this === document && type === 'DOMContentLoaded' && domReady) {
        // Defer to next tick so Turbo finishes swapping the body first
        setTimeout(function() { try { fn(); } catch(e) { console.warn('[Turbo compat]', e); } }, 0);
        return;
      }
      return origAdd.call(this, type, fn, opts);
    };
  })();
</script>
<script src="https://cdn.jsdelivr.net/npm/@hotwired/turbo@8.0.12/dist/turbo.es2017-umd.js" data-turbo-track="reload"></script>
<style>
  .turbo-progress-bar {
    height: 3px;
    background: linear-gradient(90deg, var(--color-primary, #000), var(--color-primary-dark, #333));
    box-shadow: 0 0 8px var(--color-primary, #000);
  }
</style>
<script>
  // Disable Turbo entirely on admin pages
  if (location.pathname.startsWith('/admin') && window.Turbo) {
    Turbo.session.drive = false;
  }
  // Intercept navigation TO admin pages (from storefront)
  document.addEventListener('turbo:before-visit', function(e) {
    try {
      var url = new URL(e.detail.url);
      if (url.pathname.startsWith('/admin')) {
        e.preventDefault();
        window.location.href = e.detail.url;
      }
    } catch(err) {}
  });
  // Close drawers/sidebars before Turbo navigates away
  document.addEventListener('turbo:before-render', function() {
    if (typeof closeSidebar === 'function') try { closeSidebar(); } catch(e) {}
    if (typeof closeCartDrawer === 'function') try { closeCartDrawer(); } catch(e) {}
    document.body.style.overflow = '';
  });
  // Disable Turbo for forms with file uploads
  document.addEventListener('turbo:before-fetch-request', function(e) {
    var form = e.target;
    if (form && form.tagName === 'FORM' && form.enctype === 'multipart/form-data') {
      e.preventDefault();
      form.submit();
    }
  });
  // Track page views for analytics on Turbo navigation
  document.addEventListener('turbo:load', function() {
    if (typeof gtag === 'function') gtag('event', 'page_view', { page_path: location.pathname });
    if (typeof fbq === 'function') fbq('track', 'PageView');
    if (typeof ttq !== 'undefined' && ttq.page) ttq.page();
  });
</script>
