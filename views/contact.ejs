<!DOCTYPE html>
<html lang="<%= typeof lang !== 'undefined' ? lang : 'ar' %>" dir="<%= typeof dir !== 'undefined' ? dir : 'rtl' %>">
<head>
  <%- include('partials/head') %>
  <title>اتصل بنا — <%= typeof siteName !== 'undefined' ? siteName : 'متجرنا' %></title>
</head>
<body>
  <div class="pattern-overlay"></div>

  <nav class="navbar scrolled">
    <div class="container">
      <div class="navbar__inner" style="display: flex; align-items: center; justify-content: space-between; position: relative; direction: ltr;">
        <!-- Left: Menu -->
        <div style="display: flex; align-items: center; gap: 12px; min-width: 44px;">
          <% if (typeof sidebarCategories !== 'undefined' && sidebarCategories && sidebarCategories.length > 0) { %>
          <button type="button" onclick="openSidebar()" style="background: none; border: none; font-size: 22px; cursor: pointer; color: var(--color-text); padding: 4px; line-height: 1; opacity: 0.8;" title="<%= t('menu') %>">☰</button>
          <% } %>
        </div>
        <!-- Center: Logo -->
        <div style="position: absolute; left: 50%; transform: translateX(-50%);">
          <a href="/" style="display: flex; align-items: center; gap: 10px;">
            <% if (typeof desktopLogo !== 'undefined' && desktopLogo) { %>
              <img src="/uploads/settings/<%= desktopLogo %>" alt="" style="height: <%= typeof logoSize !== 'undefined' && logoSize ? logoSize : '36' %>px; width: auto;">
            <% } else { %>
              <div class="navbar__logo"><%= typeof siteName !== 'undefined' ? siteName.charAt(0) : 'م' %></div>
              <span class="navbar__name"><%= typeof siteName !== 'undefined' ? siteName : 'متجرنا' %></span>
            <% } %>
          </a>
        </div>
        <!-- Right: Search + Home (always right) -->
        <div style="display: flex; align-items: center; gap: 12px; direction: ltr;">
          <a href="/search" style="font-size: 20px; color: var(--color-text); text-decoration: none; opacity: 0.8; padding: 4px; line-height: 1;" title="<%= t('search') %>">🔍</a>
          <a href="/" style="font-size: 20px; color: var(--color-text); text-decoration: none; opacity: 0.8; padding: 4px; line-height: 1;" title="<%= t('home') %>">🏠</a>
        </div>
      </div>
    </div>
  </nav>

  <section style="padding: 120px 0 60px;">
    <div class="container container--narrow">
      <div class="section-header animate-on-scroll">
        <span class="section-header__label">تواصل معنا</span>
        <h1 class="section-header__title">اتصل بنا</h1>
        <div class="section-header__divider"></div>
      </div>

      <!-- WhatsApp Button -->
      <% if (whatsappNumber) { %>
      <div class="animate-on-scroll" style="text-align: center; margin-bottom: 40px;">
        <a href="https://wa.me/<%= whatsappNumber.replace(/[^0-9]/g, '') %>" target="_blank" rel="noopener noreferrer" style="display: inline-flex; align-items: center; gap: 12px; background: #25D366; color: #fff; padding: 16px 40px; border-radius: var(--radius-md); font-size: 18px; font-weight: 700; text-decoration: none; transition: transform 0.2s, box-shadow 0.2s; box-shadow: 0 4px 15px rgba(37,211,102,0.3);" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          تواصل معنا عبر الواتساب
        </a>
        <p style="margin-top: 12px; color: var(--color-text-muted); font-size: 14px;">نرد على رسائلكم في أسرع وقت ممكن</p>
      </div>
      <% } %>

      <!-- Contact Form -->
      <div class="feedback-card animate-on-scroll" style="padding: 32px;">
        <h3 style="font-size: 20px; margin-bottom: 24px; color: var(--color-primary); text-align: center;">أو أرسل لنا رسالة</h3>
        <form id="contactForm" onsubmit="submitContactForm(event)">
          <div class="feedback-form__row">
            <div class="form-group">
              <label class="form-label" for="contactName">
                <span class="required">*</span> الاسم
              </label>
              <input type="text" id="contactName" name="name" class="form-input" placeholder="أدخل اسمك" required>
            </div>
            <div class="form-group">
              <label class="form-label" for="contactPhone">
                <span class="required">*</span> رقم الهاتف
              </label>
              <div class="form-input-phone-wrapper">
                <div class="form-input-phone-prefix">+212</div>
                <input type="tel" id="contactPhone" name="phone" class="form-input" placeholder="6XXXXXXXX" required dir="ltr">
              </div>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label" for="contactSubject">الموضوع</label>
            <input type="text" id="contactSubject" name="subject" class="form-input" placeholder="موضوع الرسالة">
          </div>
          <div class="form-group">
            <label class="form-label" for="contactMessage">
              <span class="required">*</span> رسالتك
            </label>
            <textarea id="contactMessage" name="message" class="form-input form-textarea" placeholder="اكتب رسالتك هنا..." rows="5" required></textarea>
          </div>
          <button type="submit" class="btn btn--primary btn--lg btn--full">إرسال الرسالة</button>
        </form>
        <div id="contactSuccess" style="display: none; text-align: center; padding: 40px 0;">
          <div style="font-size: 48px; margin-bottom: 16px;">&#10004;</div>
          <h3 style="font-size: 20px; margin-bottom: 8px;">تم إرسال رسالتك بنجاح!</h3>
          <p style="color: var(--color-text-muted);">سنتواصل معك في أقرب وقت ممكن.</p>
        </div>
      </div>
    </div>
  </section>

  <%- include('partials/footer') %>

  <script>
    function submitContactForm(e) {
      e.preventDefault();
      var form = document.getElementById('contactForm');
      var success = document.getElementById('contactSuccess');
      // Simple client-side handling - show success message
      form.style.display = 'none';
      success.style.display = 'block';
    }
  </script>
  <script src="/js/main.js"></script>
</body>
</html>
