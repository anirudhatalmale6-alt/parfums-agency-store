                    <% } %>
                    <% if (p.old_price && p.old_price > p.price) { %>
                      <span style="position: absolute; top: 8px; left: 8px; background: var(--color-discount); color: #fff; font-size: 11px; font-weight: 700; padding: 3px 8px; border-radius: 6px;">-<%= Math.round(((p.old_price - p.price) / p.old_price) * 100) %>%</span>
