  <!-- Customer Feedback Section (fallback — only if no feedback collection card exists) -->
  <% if (typeof latestReviews !== 'undefined' && latestReviews && latestReviews.length > 0 && (typeof showFeedbackSection === 'undefined' || showFeedbackSection !== false) && !feedbackCollectionId) { %>
  <section style="padding: 40px 0 50px; background: var(--color-bg-warm);">
    <div class="container container--narrow">
      <div class="section-header" style="margin-top: 0;">
        <h2 class="section-header__title"><%= t('customer_feedback') %></h2>
        <div class="section-header__divider"></div>
      </div>

      <style>
        .hrv-card { background: var(--color-card); border-radius: 16px; padding: 16px 18px; margin-bottom: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.05); border: 1px solid var(--color-border-light); }
        .hrv-card[dir="ltr"] { direction: ltr; text-align: left; }
        .hrv-card[dir="rtl"] { direction: rtl; text-align: right; }
        .hrv-card__hdr { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
        .hrv-card__av { width: 40px; height: 40px; border-radius: 50%; background: var(--color-primary); color: #fff; display: flex; align-items: center; justify-content: center; font-size: 18px; font-weight: 700; flex-shrink: 0; text-transform: uppercase; }
        .hrv-card__nm { font-size: 14px; font-weight: 700; color: var(--color-text); }
        .hrv-card__vf { display: inline-flex; width: 16px; height: 16px; flex-shrink: 0; margin-inline-start: 4px; vertical-align: middle; }
        .hrv-card__vf svg { width: 16px; height: 16px; }
        .hrv-card__body { min-height: 40px; margin-bottom: 8px; }
        .hrv-card__body .wa-audio-player { margin-top: 4px; width: 100%; min-width: 0; }
        .hrv-card__txt { font-size: 13px; line-height: 1.6; color: var(--color-text-secondary); margin: 0; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
        .hrv-card__imgs { display: flex; gap: 8px; margin-bottom: 8px; overflow-x: auto; scrollbar-width: none; }
        .hrv-card__imgs::-webkit-scrollbar { display: none; }
        .hrv-card__imgs img { width: 90px; height: 90px; object-fit: cover; border-radius: 10px; flex-shrink: 0; border: 1px solid var(--color-border-light); cursor: pointer; transition: transform 0.2s; }
        .hrv-card__imgs img:hover { transform: scale(1.05); }
        .hrv-card__stars { color: var(--color-star); font-size: 15px; letter-spacing: 2px; }
        @media (max-width: 600px) {
          .hrv-card__imgs img { width: 80px; height: 80px; }
        }
      </style>

      <div style="margin-bottom: 24px;">
        <% latestReviews.forEach(function(rev) { %>
          <%
            var _himgs = [];
            if (rev.image_filename) {
              try { _himgs = JSON.parse(rev.image_filename); } catch(e) { _himgs = [rev.image_filename]; }
              _himgs = _himgs.filter(function(img) { return !!img; });
            }
            var _hInit = (rev.name || '?').charAt(0).toUpperCase();
            var _hText = (rev.name || '') + ' ' + (rev.message || '');
            var _hIsAr = /[\u0600-\u06FF]/.test(_hText);
            var _hDir = _hIsAr ? 'rtl' : 'ltr';
          %>
          <div class="hrv-card" dir="<%= _hDir %>">
            <div class="hrv-card__hdr">
              <div class="hrv-card__av"><%= _hInit %></div>
              <div>
                <span class="hrv-card__nm"><%= rev.name || t('customer') %></span>
                <span class="hrv-card__vf"><svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" fill="#1DA1F2"/><path d="M9 12l2 2 4-4" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              </div>
            </div>
            <div class="hrv-card__body">
              <% if (rev.message) { %><p class="hrv-card__txt"><%= rev.message %></p><% } %>
              <% if (rev.audio_filename) { %>
                <div class="wa-audio-player" data-src="/uploads/reviews/<%= rev.audio_filename %>">
                  <button type="button" class="wa-play-btn" onclick="toggleWaAudio(this)" style="width: 28px; height: 28px; font-size: 11px;">▶</button>
                  <div class="wa-progress-wrap" onclick="seekWaAudio(event, this)"><div class="wa-waveform"></div></div>
                  <span class="wa-time" style="font-size: 11px;">0:00</span>
                </div>
              <% } %>
            </div>
            <% if (_himgs.length > 0) { %>
              <div class="hrv-card__imgs">
                <% _himgs.forEach(function(img) { %><img src="/uploads/reviews/<%= img %>" alt="" loading="lazy"><% }); %>
              </div>
            <% } %>
            <div class="hrv-card__stars"><% for (var i = 1; i <= 5; i++) { %><%= i <= rev.rating ? '★' : '☆' %><% } %></div>
          </div>
        <% }); %>
      </div>

      <div style="text-align: center;">
        <a href="/feedback" style="display: inline-flex; align-items: center; gap: 8px; padding: 12px 32px; background: var(--color-primary); color: #fff; text-decoration: none; border-radius: 10px; font-size: 15px; font-weight: 700; transition: opacity 0.2s;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
          <%= t('view_all_reviews') %> (<%= typeof homeReviewCount !== 'undefined' ? homeReviewCount : '' %>)
        </a>
      </div>
    </div>
  </section>
  <% } %>

  <%- include('partials/footer') %>

  <script>
    // Product slider scroll function
    function scrollSlider(id, direction) {
      var slider = document.getElementById(id);
      if (!slider) return;
      var cardWidth = slider.querySelector('.slide-card').offsetWidth + 12;
      slider.scrollBy({ left: direction * cardWidth * 2, behavior: 'smooth' });
    }

    // Auto-play sliders
    <% if (typeof collections !== 'undefined' && collections.length > 0) { %>
      <% collections.forEach(function(col) { %>
        <% if ((col.display_mode === 'slider' || col.display_mode === 'both') && col.slider_autoplay) { %>
          (function() {
            var slider = document.getElementById('pslider-<%= col.id %>');
            if (!slider) return;
            setInterval(function() {
              var maxScroll = slider.scrollWidth - slider.clientWidth;
              if (slider.scrollLeft >= maxScroll - 10) {
                slider.scrollTo({ left: 0, behavior: 'smooth' });
              } else {
                var cardWidth = slider.querySelector('.slide-card') ? slider.querySelector('.slide-card').offsetWidth + 12 : 200;
                slider.scrollBy({ left: cardWidth, behavior: 'smooth' });
              }
            }, 4000);
          })();
        <% } %>
      <% }); %>
    <% } %>

    <% if (typeof useCollections === 'undefined' || !useCollections) { %>
    // Infinite scroll with banner support (only when not using collections)
    var currentPage = 1;
    var isLoadingMore = false;
    var hasMoreProducts = <%= products.length >= 6 ? 'true' : 'false' %>;
    var totalProductCount = <%= products.length %>;
    var bannerIdx = <%= typeof _bIdx !== 'undefined' ? _bIdx : 0 %>;

    window.addEventListener('scroll', function() {
      if (isLoadingMore || !hasMoreProducts) return;
      if ((window.innerHeight + window.scrollY) >= document.body.offsetHeight - 300) {
        loadMoreProducts();
      }
    });

    function createBannerHtml(banner) {
      var html = '<div class="grid-banner" style="grid-column: 1 / -1; border-radius: 12px; overflow: hidden;">';
      if (banner.link_url) html += '<a href="' + banner.link_url + '" style="display:block;">';
      html += '<picture>';
      if (banner.mobile_image) html += '<source media="(max-width: 600px)" srcset="/uploads/banners/' + banner.mobile_image + '">';
      html += '<img src="/uploads/banners/' + banner.desktop_image + '" alt="" style="width: 100%; height: auto; display: block; border-radius: 12px;" loading="lazy">';
      html += '</picture>';
      if (banner.link_url) html += '</a>';
      html += '</div>';
      return html;
    }

    function loadMoreProducts() {
      if (isLoadingMore || !hasMoreProducts) return;
      isLoadingMore = true;
      currentPage++;
      document.getElementById('loadingMore').style.display = 'block';

      fetch('/api/products?page=' + currentPage + '&limit=6')
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.products && data.products.length > 0) {
          var grid = document.querySelector('.products-grid');
          var apiBanners = data.banners || [];
          var apiInterval = data.bannerInterval || 4;

          data.products.forEach(function(p) {
            if (apiBanners.length > 0 && totalProductCount > 0 && totalProductCount % apiInterval === 0) {
              var b = apiBanners[bannerIdx % apiBanners.length];
              bannerIdx++;
              var bannerDiv = document.createElement('div');
              bannerDiv.innerHTML = createBannerHtml(b);
              grid.appendChild(bannerDiv.firstChild);
            }
            totalProductCount++;

            var card = document.createElement('a');
            card.href = '/product/' + p.slug;
            card.className = 'product-card';
            card.style.cssText = 'text-decoration: none; cursor: pointer; background: var(--color-card); border-radius: 12px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,0.06); transition: transform 0.2s, box-shadow 0.2s; display: block;';

            var imgHtml = '';
            if (p.main_image) {
              imgHtml = '<img src="/uploads/products/' + p.main_image + '" alt="' + p.title + '" style="width: 100%; height: 100%; object-fit: cover;" loading="lazy">';
            } else {
              imgHtml = '<div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 48px; color: #ccc;">&#x1f6cd;&#xfe0f;</div>';
            }

            var discountBadge = '';
            if (p.old_price && p.old_price > p.price) {
              discountBadge = '<span style="position: absolute; top: 8px; left: 8px; background: var(--color-discount); color: #fff; font-size: 11px; font-weight: 700; padding: 3px 8px; border-radius: 6px;">-' + Math.round(((p.old_price - p.price) / p.old_price) * 100) + '%</span>';
            }

            var oldPriceHtml = '';
            if (p.old_price && p.old_price > p.price) {
              oldPriceHtml = '<span style="font-size: 12px; color: var(--color-text-muted); text-decoration: line-through;">' + p.old_price + '</span>';
            }

            card.innerHTML = '<div style="width: 100%; aspect-ratio: 1; overflow: hidden; background: var(--color-bg-warm); position: relative;">' + imgHtml + discountBadge + '</div>' +
              '<div style="padding: 10px 12px 14px;">' +
              '<h3 style="font-size: 13px; font-weight: 600; color: var(--color-text); margin: 0 0 6px; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">' + p.title + '</h3>' +
              '<div style="display: flex; align-items: baseline; gap: 6px; flex-wrap: wrap;">' +
              '<span style="font-size: 16px; font-weight: 800; color: var(--color-primary);">' + p.price + ' <span style="font-size: 12px; font-weight: 600;"><%= t("currency") %></span></span>' +
              oldPriceHtml +
              '</div></div>';

            grid.appendChild(card);
          });
          hasMoreProducts = data.hasMore;
        } else {
          hasMoreProducts = false;
        }
        isLoadingMore = false;
        document.getElementById('loadingMore').style.display = 'none';
      })
      .catch(function() {
        isLoadingMore = false;
        document.getElementById('loadingMore').style.display = 'none';
      });
    }
    <% } %>

    // Slider logic
    var currentSlide = 0;
    var totalSlides = <%= typeof sliders !== 'undefined' && sliders ? sliders.length : 0 %>;

    function slideTo(index) {
      currentSlide = index;
      var container = document.getElementById('sliderContainer');
      if (container) {
        container.style.transform = 'translateX(' + (currentSlide * (100 / totalSlides)) + '%)';
      }
      document.querySelectorAll('.slider-dot').forEach(function(dot, i) {
        dot.style.background = i === currentSlide ? 'var(--color-primary)' : 'rgba(255,255,255,0.6)';
        dot.classList.toggle('active', i === currentSlide);
      });
    }

    function slideNext() {
      slideTo((currentSlide + 1) % totalSlides);
    }

    function slidePrev() {
      slideTo((currentSlide - 1 + totalSlides) % totalSlides);
    }

    // Auto-slide
    if (totalSlides > 1) {
      setInterval(function() { slideNext(); }, 5000);
    }
  </script>
  <script src="/js/main.js"></script>
</body>
</html>
