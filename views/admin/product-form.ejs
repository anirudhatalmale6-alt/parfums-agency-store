<!DOCTYPE html>
<html lang="<%= typeof lang !== 'undefined' ? lang : 'ar' %>" dir="<%= typeof dir !== 'undefined' ? dir : 'rtl' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= product ? 'تعديل المنتج' : 'اضافة منتج' %> — لوحة التحكم</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Cairo', sans-serif;
            background: #f5f1ed;
            direction: rtl;
            text-align: right;
            min-height: 100vh;
        }
        .admin-wrapper { display: flex; min-height: 100vh; }
        .sidebar {
            width: 260px; background: #6B5335; color: #fff;
            position: fixed; top: 0; right: 0; bottom: 0; z-index: 100;
            display: flex; flex-direction: column; transition: transform 0.3s;
            overflow-y: auto;
        }
        .sidebar-header { padding: 28px 24px 20px; border-bottom: 1px solid rgba(255,255,255,0.1); }
        .sidebar-header h2 { font-size: 20px; font-weight: 700; }
        .sidebar-header p { font-size: 12px; opacity: 0.6; margin-top: 2px; }
        .sidebar-nav { list-style: none; padding: 16px 0; flex: 1; }
        .sidebar-nav li a {
            display: flex; align-items: center; gap: 12px;
            padding: 12px 24px; color: rgba(255,255,255,0.75);
            text-decoration: none; font-size: 15px; font-weight: 600; transition: all 0.2s;
        }
        .sidebar-nav li a:hover, .sidebar-nav li a.active { background: rgba(255,255,255,0.1); color: #fff; }
        .sidebar-nav li a.active { border-left: 3px solid #fff; }
        .sidebar-nav li a svg { width: 20px; height: 20px; fill: currentColor; flex-shrink: 0; }
        .sidebar-divider { height: 1px; background: rgba(255,255,255,0.1); margin: 8px 24px; }
        .sidebar-footer { padding: 16px 24px; border-top: 1px solid rgba(255,255,255,0.1); }
        .sidebar-footer a { display: flex; align-items: center; gap: 12px; color: rgba(255,255,255,0.6); text-decoration: none; font-size: 14px; font-weight: 600; transition: color 0.2s; }
        .sidebar-footer a:hover { color: #fff; }
        .sidebar-footer a svg { width: 20px; height: 20px; fill: currentColor; }
        .main-content { flex: 1; margin-right: 260px; padding: 32px; }
        .page-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 28px; flex-wrap: wrap; gap: 12px; }
        .page-title { font-size: 26px; font-weight: 700; color: #6B5335; }
        .btn {
            display: inline-block; padding: 10px 24px; border: none; border-radius: 10px;
            font-family: 'Cairo', sans-serif; font-size: 14px; font-weight: 700;
            cursor: pointer; text-decoration: none; transition: opacity 0.2s;
        }
        .btn:hover { opacity: 0.85; }
        .btn-primary { background: #8B6F47; color: #fff; }
        .btn-secondary { background: #e8e0d8; color: #6B5335; }
        .btn-success { background: #e8f5e9; color: #2e7d32; }
        .btn-lg { padding: 14px 40px; font-size: 16px; }
        /* Form Styles */
        .form-card {
            background: #fff; border-radius: 14px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.04); padding: 32px; max-width: 800px;
        }
        .form-group { margin-bottom: 24px; }
        .form-group label {
            display: block; font-size: 14px; font-weight: 700;
            color: #555; margin-bottom: 8px;
        }
        .form-group input[type="text"],
        .form-group input[type="number"],
        .form-group input[type="file"],
        .form-group textarea,
        .form-group select {
            width: 100%; padding: 12px 16px;
            border: 2px solid #e8e0d8; border-radius: 10px;
            font-family: 'Cairo', sans-serif; font-size: 14px; color: #333;
            transition: border-color 0.2s; direction: rtl; text-align: right;
        }
        .form-group input:focus,
        .form-group textarea:focus,
        .form-group select:focus { outline: none; border-color: #8B6F47; }
        .form-group textarea { min-height: 120px; resize: vertical; }
        .form-group .hint {
            font-size: 12px; color: #aaa; margin-top: 6px;
        }
        .form-row {
            display: grid; grid-template-columns: 1fr 1fr; gap: 20px;
        }
        .form-row-3 {
            display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px;
        }
        .checkbox-group {
            display: flex; align-items: center; gap: 10px;
        }
        .checkbox-group input[type="checkbox"] {
            width: 20px; height: 20px; accent-color: #8B6F47; cursor: pointer;
        }
        .checkbox-group label {
            margin-bottom: 0; cursor: pointer; font-size: 15px;
        }
        .form-actions {
            display: flex; gap: 12px; margin-top: 32px; padding-top: 24px;
            border-top: 1px solid #f0ebe5;
        }
        .current-image {
            margin-top: 10px; display: inline-block; position: relative;
            border: 2px solid #e8e0d8; border-radius: 10px; overflow: hidden;
        }
        .current-image img {
            display: block; max-width: 200px; max-height: 150px; object-fit: cover;
        }
        .gallery-grid {
            display: flex; flex-wrap: wrap; gap: 12px; margin-top: 10px;
        }
        .gallery-item {
            position: relative; border: 2px solid #e8e0d8; border-radius: 10px;
            overflow: hidden; width: 120px; height: 120px;
        }
        .gallery-item img {
            width: 100%; height: 100%; object-fit: cover; display: block;
        }
        .gallery-item .delete-btn {
            position: absolute; top: 4px; left: 4px; background: rgba(220,53,69,0.9);
            color: #fff; border: none; border-radius: 50%; width: 28px; height: 28px;
            font-size: 16px; cursor: pointer; display: flex; align-items: center;
            justify-content: center; line-height: 1; font-weight: 700;
        }
        .gallery-item .delete-btn:hover { background: #dc3545; }
        .section-box {
            background: #faf7f3; border-radius: 12px; padding: 24px;
            margin-bottom: 24px; border: 2px solid #e8e0d8;
        }
        .section-box h3 { font-size: 18px; color: #6B5335; margin-bottom: 16px; }
        .variation-item {
            display: flex; align-items: center; gap: 12px; background: #fff;
            border-radius: 10px; padding: 14px 18px; margin-bottom: 10px;
            border: 1px solid #e8e0d8;
        }
        .variation-item .var-info { flex: 1; }
        .variation-item .var-label { font-weight: 700; font-size: 15px; color: #333; }
        .variation-item .var-type { font-size: 13px; color: #888; margin-top: 2px; }
        .color-swatch {
            width: 24px; height: 24px; border-radius: 50%;
            border: 2px solid #ddd; display: inline-block; vertical-align: middle;
        }
        .mobile-toggle {
            display: none; position: fixed; top: 16px; right: 16px; z-index: 200;
            background: #6B5335; color: #fff; border: none; border-radius: 10px;
            width: 44px; height: 44px; font-size: 20px; cursor: pointer;
        }
        .sidebar-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 90; }
        @media (max-width: 768px) {
            .mobile-toggle { display: block; }
            .sidebar { transform: translateX(100%); }
            .sidebar.open { transform: translateX(0); }
            .sidebar-overlay.open { display: block; }
            .main-content { margin-right: 0; padding: 24px 16px; padding-top: 72px; }
            .form-row, .form-row-3 { grid-template-columns: 1fr; }
            .form-card { padding: 24px 20px; }
        }
    </style>
</head>
<body>
    <button class="mobile-toggle" onclick="document.querySelector('.sidebar').classList.toggle('open'); document.querySelector('.sidebar-overlay').classList.toggle('open');">&#9776;</button>
    <div class="sidebar-overlay" onclick="document.querySelector('.sidebar').classList.remove('open'); this.classList.remove('open');"></div>

    <div class="admin-wrapper">
        <aside class="sidebar">
            <div class="sidebar-header">
                <h2>لوحة التحكم</h2>
                <p>ادارة المتجر</p>
            </div>
            <ul class="sidebar-nav">
                <li><a href="/admin">
                    <svg viewBox="0 0 24 24"><path d="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z"/></svg>
                    الرئيسية
                </a></li>
                <li><a href="/admin/products" class="active">
                    <svg viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 14H4V6h16v12zM6 10h2v2H6zm0 4h8v2H6zm10 0h2v2h-2zm-6-4h8v2h-8z"/></svg>
                    المنتجات
                </a></li>
                <li><a href="/admin/orders">
                    <svg viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-2 10H7v-2h10v2z"/></svg>
                    الطلبات
                </a></li>
                <li><a href="/admin/reviews">
                    <svg viewBox="0 0 24 24"><path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H6l-2 2V4h16v12z"/></svg>
                    التعليقات
                </a></li>
                <div class="sidebar-divider"></div>
                <li><a href="/admin/categories"><svg viewBox="0 0 24 24"><path d="M12 2l-5.5 9h11L12 2zm0 3.84L13.93 9h-3.87L12 5.84zM17.5 13c-2.49 0-4.5 2.01-4.5 4.5s2.01 4.5 4.5 4.5 4.5-2.01 4.5-4.5-2.01-4.5-4.5-4.5zm0 7c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5zM3 21.5h8v-8H3v8zm2-6h4v4H5v-4z"/></svg>التصنيفات</a></li>
                <li><a href="/admin/collections"><svg viewBox="0 0 24 24"><path d="M4 6H2v14c0 1.1.9 2 2 2h14v-2H4V6zm16-4H8c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H8V4h12v12zM10 9h8v2h-8zm0 3h4v2h-4zm0-6h8v2h-8z"/></svg>المجموعات</a></li>
                <li><a href="/admin/landing-pages">
                    <svg viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14zM7 10h2v7H7zm4-3h2v10h-2zm4 6h2v4h-2z"/></svg>
                    صفحات الهبوط
                <li><a href="/admin/pages"><svg viewBox="0 0 24 24"><path d="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zm4 18H6V4h7v5h5v11zM8 15.01V17h1.99l5.88-5.88-1.99-1.99L8 15.01zm7.87-7.87l1.99 1.99.86-.86c.39-.39.39-1.02 0-1.41l-.59-.59c-.39-.39-1.02-.39-1.41 0l-.85.87z"/></svg>الصفحات</a></li>
                </a></li>
                <li><a href="/admin/banners"><svg viewBox="0 0 24 24"><path d="M19 5H5c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 12H5V7h14v10zM6 13h2v2H6zm0-4h12v2H6zm4 4h8v2h-8z"/></svg>البانرات</a></li>
                <li><a href="/admin/gifts">
                    <svg viewBox="0 0 24 24"><path d="M20 6h-2.18c.11-.31.18-.65.18-1 0-1.66-1.34-3-3-3-1.05 0-1.96.54-2.5 1.35l-.5.67-.5-.68C10.96 2.54 10.05 2 9 2 7.34 2 6 3.34 6 5c0 .35.07.69.18 1H4c-1.11 0-1.99.89-1.99 2L2 19c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V8c0-1.11-.89-2-2-2zm-5-2c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zM9 4c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm11 15H4v-2h16v2zm0-5H4V8h5.08L7 10.83 8.62 12 11 8.76l1-1.36 1 1.36L15.38 12 17 10.83 14.92 8H20v6z"/></svg>
                    الهدايا
                </a></li>
                <div class="sidebar-divider"></div>
                <li><a href="/admin/users">
                    <svg viewBox="0 0 24 24"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/></svg>
                    المسوقين
                </a></li>
                <li><a href="/admin/withdrawals">
                    <svg viewBox="0 0 24 24"><path d="M21 18v1c0 1.1-.9 2-2 2H5c-1.11 0-2-.9-2-2V5c0-1.1.89-2 2-2h14c1.1 0 2 .9 2 2v1h-9c-1.11 0-2 .9-2 2v8c0 1.1.89 2 2 2h9zm-9-2h10V8H12v8zm4-2.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/></svg>
                    طلبات السحب
                </a></li>
                <div class="sidebar-divider"></div>
                <li><a href="/admin/settings/bank">
                    <svg viewBox="0 0 24 24"><path d="M4 10v7h3v-7H4zm6 0v7h3v-7h-3zM2 22h19v-3H2v3zm14-12v7h3v-7h-3zm-4.5-9L2 6v2h19V6l-9.5-5z"/></svg>
                    التحويل البنكي
                <li><a href="/admin/shipping-companies"><svg viewBox="0 0 24 24"><path d="M20 8h-3V4H3c-1.1 0-2 .9-2 2v11h2c0 1.66 1.34 3 3 3s3-1.34 3-3h6c0 1.66 1.34 3 3 3s3-1.34 3-3h2v-5l-3-4zM6 18.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm13.5-9l1.96 2.5H17V9.5h2.5zm-1.5 9c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/></svg>شركات التوصيل</a></li>
                </a></li>
                <li><a href="/admin/settings">
                    <svg viewBox="0 0 24 24"><path d="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.07.62-.07.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"/></svg>
                    الاعدادات
                </a></li>
            </ul>
            <div class="sidebar-footer">
                <a href="/admin/logout">
                    <svg viewBox="0 0 24 24"><path d="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z"/></svg>
                    تسجيل الخروج
                </a>
            </div>
        </aside>

        <main class="main-content">
            <div class="page-header">
                <h1 class="page-title"><%= product ? 'تعديل المنتج' : 'اضافة منتج جديد' %></h1>
                <div style="display:flex; gap:10px; flex-wrap:wrap;">
                    <% if (product) { %>
                        <a href="/product/<%= product.slug %>" target="_blank" class="btn" style="background: #1565c0; color: #fff;">معاينة المنتج</a>
                        <form method="POST" action="/admin/products/<%= product.id %>/duplicate" style="margin:0;">
                            <button type="submit" class="btn" style="background: #7b1fa2; color: #fff;" onclick="return confirm('هل تريد تكرار هذا المنتج؟');">تكرار المنتج</button>
                        </form>
                    <% } %>
                    <a href="/admin/products" class="btn btn-secondary">&#8592; رجوع للمنتجات</a>
                </div>
            </div>

            <% if (typeof success !== 'undefined' && success) { %>
            <div style="background: #d4edda; color: #155724; border: 1px solid #c3e6cb; border-radius: 10px; padding: 14px 20px; margin-bottom: 20px; font-weight: 600;">
                ✅ تم حفظ التعديلات بنجاح
            </div>
            <% } %>
            <% if (typeof error !== 'undefined' && error) { %>
            <div style="background: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; border-radius: 10px; padding: 14px 20px; margin-bottom: 20px; font-weight: 600;">
                ❌ حدث خطأ أثناء الحفظ. حاول مرة أخرى
            </div>
            <% } %>

            <div class="form-card">
                <form method="POST" action="<%= product ? '/admin/products/' + product.id : '/admin/products' %>" enctype="multipart/form-data">

                    <div class="form-group">
                        <label>اسم المنتج *</label>
                        <input type="text" name="title" value="<%= product ? product.title : '' %>" placeholder="ادخل اسم المنتج" required>
                    </div>

                    <div class="form-group">
                        <label>الوصف</label>
                        <textarea name="description" placeholder="وصف تفصيلي للمنتج"><%= product ? product.description : '' %></textarea>
                    </div>

                    <!-- Category Selection -->
                    <div class="form-group">
                        <label>التصنيف</label>
                        <select name="category_id" style="width: 100%; padding: 10px; border: 2px solid #e8e0d8; border-radius: 8px; font-size: 14px; font-family: inherit; background: #fff;">
                            <option value="">بدون تصنيف</option>
                            <% if (typeof categories !== 'undefined' && categories) { %>
                              <% categories.forEach(function(cat) { %>
                                <option value="<%= cat.id %>" <%= product && product.category_id == cat.id ? 'selected' : '' %>><%= cat.name %></option>
                              <% }); %>
                            <% } %>
                        </select>
                    </div>

                    <div class="form-row-3">
                        <div class="form-group">
                            <label>السعر (د.م) *</label>
                            <input type="number" name="price" step="0.01" value="<%= product ? product.price : '' %>" placeholder="0.00" required>
                        </div>
                        <div class="form-group">
                            <label>السعر القديم (د.م)</label>
                            <input type="number" name="old_price" step="0.01" value="<%= product && product.old_price ? product.old_price : '' %>" placeholder="0.00">
                            <div class="hint">يظهر مشطوبا اذا تم تعيينه</div>
                        </div>
                        <div class="form-group">
                            <label>الخصم (%)</label>
                            <input type="number" name="discount" step="1" min="0" max="100" value="<%= product && product.discount ? product.discount : '' %>" placeholder="0">
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>الرابط (slug) *</label>
                            <input type="text" name="slug" value="<%= product ? product.slug : '' %>" placeholder="product-name" required dir="ltr" style="text-align:left;">
                            <div class="hint">يستخدم في رابط المنتج - حروف انجليزية وشرطات فقط</div>
                        </div>
                        <div class="form-group">
                            <label>مبلغ العربون (د.م)</label>
                            <input type="number" name="deposit_amount" step="0.01" value="<%= product && product.deposit_amount ? product.deposit_amount : '' %>" placeholder="0.00">
                        </div>
                    </div>

                    <div class="form-row-3">
                        <div class="form-group">
                            <label>رقم واتساب</label>
                            <input type="text" name="whatsapp_number" value="<%= product ? (product.whatsapp_number || '') : '' %>" placeholder="212600000000+" dir="ltr" style="text-align:left;">
                            <div class="hint">مع رمز الدولة</div>
                        </div>
                        <div class="form-group">
                            <label>رسوم التوصيل (د.م)</label>
                            <input type="number" name="delivery_fee" step="0.01" value="<%= product ? (product.delivery_fee != null ? product.delivery_fee : 50) : 50 %>" placeholder="50">
                        </div>
                        <div class="form-group">
                            <label>الوزن (كجم)</label>
                            <input type="number" name="weight" step="0.01" value="<%= product ? (product.weight || 0) : '' %>" placeholder="0.00">
                        </div>
                    </div>

                    <!-- Payment Options -->
                    <div style="background: #f3faf3; border-radius: 12px; padding: 20px; margin-bottom: 24px; border: 2px solid #d8e8d8;">
                        <h3 style="font-size: 16px; color: #2e7d32; margin-bottom: 14px;">خيارات الدفع</h3>
                        <div style="display: flex; flex-wrap: wrap; gap: 24px;">
                            <div class="checkbox-group">
                                <input type="checkbox" name="cod_enabled" id="cod_enabled" value="1" <%= product && product.cod_enabled ? 'checked' : '' %>>
                                <label for="cod_enabled">الدفع عند الاستلام (COD)</label>
                            </div>
                            <div class="checkbox-group">
                                <input type="checkbox" name="bank_full_enabled" id="bank_full_enabled" value="1" <%= product ? (product.bank_full_enabled ? 'checked' : '') : 'checked' %>>
                                <label for="bank_full_enabled">تحويل بنكي كامل</label>
                            </div>
                            <div class="checkbox-group">
                                <input type="checkbox" name="bank_deposit_enabled" id="bank_deposit_enabled" value="1" <%= product ? (product.bank_deposit_enabled ? 'checked' : '') : 'checked' %>>
                                <label for="bank_deposit_enabled">عربون بنكي</label>
                            </div>
                        </div>
                    </div>

                    <!-- Inventory Section -->
                    <div style="background: #fff8e1; border-radius: 12px; padding: 20px; margin-bottom: 24px; border: 2px solid #ffe082;">
                        <h3 style="font-size: 16px; color: #f57f17; margin-bottom: 14px;">المخزون والتوفر</h3>
                        <div style="display: flex; flex-wrap: wrap; gap: 20px;">
                            <div class="form-group" style="flex: 1; min-width: 180px; margin-bottom: 0;">
                                <label>الكمية المتوفرة</label>
                                <input type="number" name="stock_quantity" min="-1" value="<%= product ? (product.stock_quantity != null ? product.stock_quantity : -1) : -1 %>" style="width: 100%; padding: 10px; border: 2px solid #e8e0d8; border-radius: 8px; font-size: 14px;">
                                <div class="hint">-1 = غير محدود (بدون تتبع مخزون)</div>
                            </div>
                            <div class="form-group" style="flex: 1; min-width: 180px; margin-bottom: 0;">
                                <label>حالة التوفر</label>
                                <select name="availability_status" style="width: 100%; padding: 10px; border: 2px solid #e8e0d8; border-radius: 8px; font-size: 14px; font-family: inherit; background: #fff;">
                                    <% var avail = product ? (product.availability_status || 'in_stock') : 'in_stock'; %>
                                    <option value="in_stock" <%= avail === 'in_stock' ? 'selected' : '' %>>متوفر</option>
                                    <option value="out_of_stock" <%= avail === 'out_of_stock' ? 'selected' : '' %>>غير متوفر</option>
                                    <option value="preorder" <%= avail === 'preorder' ? 'selected' : '' %>>طلب مسبق</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- Per-Product SEO -->
                    <div style="background: #e8f5e9; border-radius: 12px; padding: 20px; margin-bottom: 24px; border: 2px solid #c8e6c9;">
                        <h3 style="font-size: 16px; color: #2e7d32; margin-bottom: 14px;">SEO — تحسين محركات البحث</h3>
                        <div class="form-group" style="margin-bottom: 14px;">
                            <label>عنوان SEO (Meta Title)</label>
                            <input type="text" name="meta_title" value="<%= product ? (product.meta_title || '') : '' %>" placeholder="يظهر في تبويب المتصفح ونتائج البحث" style="width: 100%; padding: 10px; border: 2px solid #e8e0d8; border-radius: 8px; font-size: 14px;" dir="auto">
                            <div class="hint">اتركه فارغ لاستخدام اسم المنتج — 50-60 حرف مثالي</div>
                        </div>
                        <div class="form-group" style="margin-bottom: 0;">
                            <label>وصف SEO (Meta Description)</label>
                            <textarea name="meta_description" rows="2" placeholder="وصف مختصر يظهر في نتائج البحث" style="width: 100%; padding: 10px; border: 2px solid #e8e0d8; border-radius: 8px; font-size: 14px; font-family: inherit; resize: vertical;" dir="auto"><%= product ? (product.meta_description || '') : '' %></textarea>
                            <div class="hint">120-160 حرف مثالي</div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>الصورة الرئيسية</label>
                        <div id="mainImageDropZone" style="
                            border: 3px dashed #d4c8b8; border-radius: 14px; padding: 32px 20px;
                            text-align: center; cursor: pointer; transition: all 0.3s;
                            background: #fdfcfa; position: relative;
                        " onclick="document.getElementById('mainImageInput').click();"
                           ondragover="event.preventDefault(); this.style.borderColor='#8B6F47'; this.style.background='#f5efe8';"
                           ondragleave="this.style.borderColor='#d4c8b8'; this.style.background='#fdfcfa';"
                           ondrop="event.preventDefault(); this.style.borderColor='#d4c8b8'; this.style.background='#fdfcfa'; var input=document.getElementById('mainImageInput'); input.files=event.dataTransfer.files; handleMainImagePreview(input);">
                            <div id="mainImageDropContent">
                                <div style="font-size: 48px; margin-bottom: 12px; opacity: 0.5;">📸</div>
                                <div style="font-size: 16px; font-weight: 700; color: #6B5335; margin-bottom: 6px;">اسحب الصورة هنا أو اضغط للاختيار</div>
                                <div style="font-size: 13px; color: #aaa;">JPG, PNG, WebP — يُنصح بصورة 800x800 بكسل</div>
                            </div>
                            <div id="mainImagePreview" style="display: none;">
                                <img id="mainImagePreviewImg" src="" alt="معاينة" style="max-width: 280px; max-height: 220px; border-radius: 10px; object-fit: cover; box-shadow: 0 2px 12px rgba(0,0,0,0.1);">
                                <div id="mainImagePreviewName" style="font-size: 13px; color: #2e7d32; margin-top: 10px; font-weight: 600;"></div>
                                <button type="button" onclick="event.stopPropagation(); clearMainImagePreview();" style="margin-top: 8px; background: #ffebee; color: #c62828; border: none; border-radius: 8px; padding: 6px 16px; font-size: 13px; font-weight: 700; cursor: pointer; font-family: inherit;">✕ إزالة</button>
                            </div>
                        </div>
                        <input type="file" name="main_image" id="mainImageInput" accept="image/*" style="display: none;" onchange="handleMainImagePreview(this);">
                        <% if (product && product.main_image) { %>
                            <div class="current-image">
                                <img src="/uploads/products/<%= product.main_image %>" alt="الصورة الرئيسية">
                            </div>
                            <div class="hint" style="color: #2e7d32;">صورة حالية: <%= product.main_image %> - ارفع صورة جديدة لاستبدالها</div>
                        <% } %>
                    </div>

                    <div class="form-group">
                        <label>صور المعرض</label>
                        <input type="file" name="gallery_images" accept="image/*" multiple>
                        <div class="hint">يمكنك رفع عدة صور للمعرض (حتى 20 صورة)</div>
                        <% if (product && product.gallery_images && product.gallery_images.length > 0) { %>
                            <div class="gallery-grid">
                                <% product.gallery_images.forEach(function(img) { %>
                                    <div class="gallery-item">
                                        <img src="/uploads/products/<%= img.filename %>" alt="صورة معرض">
                                        <form method="POST" action="/admin/products/<%= product.id %>/delete-image" style="margin:0;">
                                            <input type="hidden" name="image_id" value="<%= img.id %>">
                                            <button type="submit" class="delete-btn" title="حذف" onclick="return confirm('هل تريد حذف هذه الصورة؟');">&times;</button>
                                        </form>
                                    </div>
                                <% }); %>
                            </div>
                        <% } %>
                    </div>

                    <div class="form-group">
                        <div class="checkbox-group">
                            <input type="checkbox" name="show_gallery" id="show_gallery" value="1" <%= product ? (product.show_gallery ? 'checked' : '') : 'checked' %>>
                            <label for="show_gallery">اظهار قسم المعرض في صفحة المنتج</label>
                        </div>
                    </div>

                    <div class="form-group">
                        <div class="checkbox-group">
                            <input type="checkbox" name="show_reviews" id="show_reviews" value="1" <%= product ? (product.show_reviews ? 'checked' : '') : 'checked' %>>
                            <label for="show_reviews">عرض تعليقات وتقييمات العملاء في صفحة المنتج</label>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>صور الوصف</label>
                        <input type="file" name="description_images" accept="image/*" multiple>
                        <div class="hint">صور اضافية تظهر في قسم الوصف (حتى 10 صور)</div>
                        <% if (product) { %>
                            <% var descImages = []; try { descImages = JSON.parse(product.description_images || '[]'); } catch(e) {} %>
                            <% if (descImages.length > 0) { %>
                                <div class="gallery-grid">
                                    <% descImages.forEach(function(imgFile) { %>
                                        <div class="gallery-item">
                                            <img src="/uploads/products/<%= imgFile %>" alt="صورة وصف">
                                            <form method="POST" action="/admin/products/<%= product.id %>/delete-desc-image" style="margin:0;">
                                                <input type="hidden" name="filename" value="<%= imgFile %>">
                                                <button type="submit" class="delete-btn" title="حذف" onclick="return confirm('هل تريد حذف هذه الصورة؟');">&times;</button>
                                            </form>
                                        </div>
                                    <% }); %>
                                </div>
                            <% } %>
                        <% } %>
                    </div>

                    <div class="form-group">
                        <label>فيديو المنتج</label>
                        <input type="file" name="video" accept="video/*">
                        <% if (product && product.video_filename) { %>
                            <div class="hint" style="color: #2e7d32;">فيديو حالي: <%= product.video_filename %></div>
                        <% } %>
                    </div>

                    <!-- Audio File -->
                    <div style="background: #f3f3fa; border-radius: 12px; padding: 20px; margin-bottom: 24px; border: 2px solid #d8d8e8;">
                        <h3 style="font-size: 16px; color: #335b6b; margin-bottom: 14px;">ملف صوتي</h3>
                        <div class="form-group" style="margin-bottom:12px;">
                            <label>ملف الصوت (mp3, wav)</label>
                            <input type="file" name="audio" accept="audio/mp3,audio/wav,audio/mpeg,.mp3,.wav">
                            <% if (product && product.audio_filename) { %>
                                <div class="hint" style="color: #2e7d32; margin-top: 8px;">ملف حالي: <%= product.audio_filename %></div>
                                <audio controls preload="none" style="margin-top:8px; width: 100%;">
                                    <source src="/uploads/products/<%= product.audio_filename %>">
                                </audio>
                            <% } %>
                        </div>
                        <div class="checkbox-group">
                            <input type="checkbox" name="audio_autoplay" id="audio_autoplay" value="1" <%= product && product.audio_autoplay ? 'checked' : '' %>>
                            <label for="audio_autoplay">تشغيل تلقائي للصوت عند فتح صفحة المنتج</label>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>المميزات (JSON)</label>
                        <textarea name="features" placeholder='[{"icon":"...","title":"ميزة","desc":"الوصف"}]' style="min-height:100px; direction:ltr; text-align:left; font-family: monospace; display:none;"><%= product && product.features ? (typeof product.features === 'string' ? product.features : JSON.stringify(product.features, null, 2)) : '[]' %></textarea>
                    </div>

                    <!-- Features Visual Editor -->
                    <% if (product) { %>
                    <div style="background: #faf7f3; border-radius: 12px; padding: 24px; margin-bottom: 24px; border: 2px solid #e8e0d8;">
                        <h3 style="font-size: 18px; color: #6B5335; margin-bottom: 16px;">المميزات — لماذا منتجنا؟</h3>
                        <% var featuresList = []; try { featuresList = typeof product.features === 'string' ? JSON.parse(product.features || '[]') : (product.features || []); } catch(e) {} %>
                        <% if (featuresList.length > 0) { %>
                            <% featuresList.forEach(function(feat, idx) { %>
                                <div style="display: flex; align-items: center; gap: 12px; background: #fff; border-radius: 10px; padding: 14px 18px; margin-bottom: 10px; border: 1px solid #e8e0d8;">
                                    <span style="font-size: 28px; flex-shrink: 0;"><%= feat.icon || '' %></span>
                                    <div style="flex: 1;">
                                        <div style="font-weight: 700; font-size: 15px; color: #333;"><%= feat.title %></div>
                                        <div style="font-size: 13px; color: #888; margin-top: 2px;"><%= feat.desc || '' %></div>
                                    </div>
                                    <form method="POST" action="/admin/products/<%= product.id %>/feature/<%= idx %>/delete" style="margin:0;">
                                        <button type="submit" onclick="return confirm('حذف هذه الميزة؟');" style="background: #dc3545; color: #fff; border: none; border-radius: 8px; width: 32px; height: 32px; font-size: 16px; cursor: pointer; font-weight: 700;">x</button>
                                    </form>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <p style="color: #aaa; font-size: 14px; text-align: center; padding: 16px;">لا توجد مميزات بعد — أضف من الأسفل</p>
                        <% } %>
                        <form method="POST" action="/admin/products/<%= product.id %>/feature" style="margin-top: 16px; display: flex; flex-wrap: wrap; gap: 10px; align-items: flex-end;">
                            <div style="width: 70px;">
                                <label style="font-size: 12px; color: #888; display: block; margin-bottom: 4px;">أيقونة</label>
                                <input type="text" name="icon" placeholder="..." style="width: 100%; padding: 10px; border: 2px solid #e8e0d8; border-radius: 8px; font-size: 20px; text-align: center;">
                            </div>
                            <div style="flex: 1; min-width: 150px;">
                                <label style="font-size: 12px; color: #888; display: block; margin-bottom: 4px;">العنوان *</label>
                                <input type="text" name="featureTitle" placeholder="مثلا: طبيعي 100%" required style="width: 100%; padding: 10px; border: 2px solid #e8e0d8; border-radius: 8px; font-size: 14px;">
                            </div>
                            <div style="flex: 2; min-width: 200px;">
                                <label style="font-size: 12px; color: #888; display: block; margin-bottom: 4px;">الوصف</label>
                                <input type="text" name="desc" placeholder="وصف قصير للميزة" style="width: 100%; padding: 10px; border: 2px solid #e8e0d8; border-radius: 8px; font-size: 14px;">
                            </div>
                            <button type="submit" style="background: #8B6F47; color: #fff; border: none; border-radius: 8px; padding: 10px 20px; font-weight: 700; cursor: pointer; font-family: inherit; font-size: 14px;">+ اضافة</button>
                        </form>
                    </div>
                    <% } %>

                    <!-- FAQ Section -->
                    <% if (product) { %>
                    <div style="background: #f3f7fa; border-radius: 12px; padding: 24px; margin-bottom: 24px; border: 2px solid #d8e0e8;">
                        <h3 style="font-size: 18px; color: #335b6b; margin-bottom: 16px;">الأسئلة المتكررة (FAQ)</h3>
                        <% var faqList = product.faqs || []; %>
                        <% if (faqList.length > 0) { %>
                            <% faqList.forEach(function(faq) { %>
                                <div style="background: #fff; border-radius: 10px; padding: 16px 18px; margin-bottom: 10px; border: 1px solid #d8e0e8;">
                                    <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 12px;">
                                        <div style="flex: 1;">
                                            <div style="font-weight: 700; font-size: 15px; color: #333; margin-bottom: 6px;"><%= faq.question %></div>
                                            <div style="font-size: 14px; color: #666; line-height: 1.6;"><%= faq.answer %></div>
                                        </div>
                                        <form method="POST" action="/admin/products/<%= product.id %>/faq/<%= faq.id %>/delete" style="margin:0; flex-shrink: 0;">
                                            <button type="submit" onclick="return confirm('حذف هذا السؤال؟');" style="background: #dc3545; color: #fff; border: none; border-radius: 8px; width: 32px; height: 32px; font-size: 16px; cursor: pointer; font-weight: 700;">x</button>
                                        </form>
                                    </div>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <p style="color: #aaa; font-size: 14px; text-align: center; padding: 16px;">لا توجد أسئلة بعد — أضف من الأسفل</p>
                        <% } %>
                        <form method="POST" action="/admin/products/<%= product.id %>/faq" style="margin-top: 16px;">
                            <div style="margin-bottom: 10px;">
                                <label style="font-size: 12px; color: #888; display: block; margin-bottom: 4px;">السؤال *</label>
                                <input type="text" name="question" placeholder="مثلا: هل المنتج أصلي؟" required style="width: 100%; padding: 10px; border: 2px solid #d8e0e8; border-radius: 8px; font-size: 14px; font-family: inherit;">
                            </div>
                            <div style="margin-bottom: 10px;">
                                <label style="font-size: 12px; color: #888; display: block; margin-bottom: 4px;">الجواب *</label>
                                <textarea name="answer" placeholder="الاجابة على السؤال..." required style="width: 100%; padding: 10px; border: 2px solid #d8e0e8; border-radius: 8px; font-size: 14px; min-height: 80px; resize: vertical; font-family: inherit;"></textarea>
                            </div>
                            <button type="submit" style="background: #335b6b; color: #fff; border: none; border-radius: 8px; padding: 10px 20px; font-weight: 700; cursor: pointer; font-family: inherit; font-size: 14px;">+ اضافة سؤال</button>
                        </form>
                    </div>
                    <% } %>

                    <!-- Variations Section -->
                    <% if (product) { %>
                    <div class="section-box">
                        <h3>المتغيرات (المقاسات والألوان)</h3>
                        <% var variations = product.variations || []; %>
                        <% var sizeVars = variations.filter(function(v) { return v.type === 'size'; }); %>
                        <% var colorVars = variations.filter(function(v) { return v.type === 'color'; }); %>

                        <!-- Size Variations -->
                        <div style="margin-bottom: 20px;">
                            <h4 style="font-size: 15px; color: #6B5335; margin-bottom: 10px;">المقاسات</h4>
                            <% if (sizeVars.length > 0) { %>
                                <% sizeVars.forEach(function(v) { %>
                                    <div class="variation-item">
                                        <div class="var-info">
                                            <div class="var-label"><%= v.label %></div>
                                            <% if (v.price_adjustment) { %>
                                                <div class="var-type"><%= v.price_adjustment > 0 ? '+' : '' %><%= v.price_adjustment %> د.م</div>
                                            <% } %>
                                        </div>
                                        <form method="POST" action="/admin/products/<%= product.id %>/variation/<%= v.id %>/delete" style="margin:0;">
                                            <button type="submit" onclick="return confirm('حذف هذا المقاس؟');" style="background: #dc3545; color: #fff; border: none; border-radius: 8px; width: 32px; height: 32px; font-size: 16px; cursor: pointer; font-weight: 700;">x</button>
                                        </form>
                                    </div>
                                <% }); %>
                            <% } else { %>
                                <p style="color: #aaa; font-size: 13px; padding: 8px 0;">لا توجد مقاسات</p>
                            <% } %>
                            <form method="POST" action="/admin/products/<%= product.id %>/variation" style="margin-top: 10px; display: flex; flex-wrap: wrap; gap: 10px; align-items: flex-end;">
                                <input type="hidden" name="type" value="size">
                                <div style="flex: 1; min-width: 120px;">
                                    <label style="font-size: 12px; color: #888; display: block; margin-bottom: 4px;">المقاس *</label>
                                    <input type="text" name="label" placeholder="S, M, L, XL..." required style="width: 100%; padding: 10px; border: 2px solid #e8e0d8; border-radius: 8px; font-size: 14px;">
                                </div>
                                <div style="width: 120px;">
                                    <label style="font-size: 12px; color: #888; display: block; margin-bottom: 4px;">فرق السعر</label>
                                    <input type="number" name="price_adjustment" step="0.01" value="0" style="width: 100%; padding: 10px; border: 2px solid #e8e0d8; border-radius: 8px; font-size: 14px;">
                                </div>
                                <button type="submit" style="background: #8B6F47; color: #fff; border: none; border-radius: 8px; padding: 10px 20px; font-weight: 700; cursor: pointer; font-family: inherit; font-size: 14px;">+ اضافة</button>
                            </form>
                        </div>

                        <!-- Color Variations -->
                        <div>
                            <h4 style="font-size: 15px; color: #6B5335; margin-bottom: 10px;">الألوان</h4>
                            <% if (colorVars.length > 0) { %>
                                <% colorVars.forEach(function(v) { %>
                                    <div class="variation-item">
                                        <% if (v.value) { %><span class="color-swatch" style="background:<%= v.value %>;"></span><% } %>
                                        <div class="var-info">
                                            <div class="var-label"><%= v.label %></div>
                                            <div class="var-type" style="display:flex; gap:8px; align-items:center;">
                                                <% if (v.price_adjustment) { %><span><%= v.price_adjustment > 0 ? '+' : '' %><%= v.price_adjustment %> د.م</span><% } %>
                                                <% if (v.image_filename) { %><span style="color:#2e7d32;">- صورة مرفقة</span><% } %>
                                            </div>
                                        </div>
                                        <% if (v.image_filename) { %>
                                            <img src="/uploads/variations/<%= v.image_filename %>" alt="" style="width:40px; height:40px; border-radius:8px; object-fit:cover; border:1px solid #ddd;">
                                        <% } %>
                                        <form method="POST" action="/admin/products/<%= product.id %>/variation/<%= v.id %>/delete" style="margin:0;">
                                            <button type="submit" onclick="return confirm('حذف هذا اللون؟');" style="background: #dc3545; color: #fff; border: none; border-radius: 8px; width: 32px; height: 32px; font-size: 16px; cursor: pointer; font-weight: 700;">x</button>
                                        </form>
                                    </div>
                                <% }); %>
                            <% } else { %>
                                <p style="color: #aaa; font-size: 13px; padding: 8px 0;">لا توجد ألوان</p>
                            <% } %>
                            <form method="POST" action="/admin/products/<%= product.id %>/variation" enctype="multipart/form-data" style="margin-top: 10px; display: flex; flex-wrap: wrap; gap: 10px; align-items: flex-end;">
                                <input type="hidden" name="type" value="color">
                                <div style="flex: 1; min-width: 120px;">
                                    <label style="font-size: 12px; color: #888; display: block; margin-bottom: 4px;">اسم اللون *</label>
                                    <input type="text" name="label" placeholder="أحمر, أزرق..." required style="width: 100%; padding: 10px; border: 2px solid #e8e0d8; border-radius: 8px; font-size: 14px;">
                                </div>
                                <div style="width: 80px;">
                                    <label style="font-size: 12px; color: #888; display: block; margin-bottom: 4px;">الرمز</label>
                                    <input type="color" name="value" value="#000000" style="width: 100%; height: 42px; border: 2px solid #e8e0d8; border-radius: 8px; cursor: pointer; padding: 2px;">
                                </div>
                                <div style="width: 120px;">
                                    <label style="font-size: 12px; color: #888; display: block; margin-bottom: 4px;">فرق السعر</label>
                                    <input type="number" name="price_adjustment" step="0.01" value="0" style="width: 100%; padding: 10px; border: 2px solid #e8e0d8; border-radius: 8px; font-size: 14px;">
                                </div>
                                <div style="flex: 1; min-width: 150px;">
                                    <label style="font-size: 12px; color: #888; display: block; margin-bottom: 4px;">صورة اللون</label>
                                    <input type="file" name="variation_image" accept="image/*" style="width: 100%; padding: 8px; border: 2px solid #e8e0d8; border-radius: 8px; font-size: 13px;">
                                </div>
                                <button type="submit" style="background: #8B6F47; color: #fff; border: none; border-radius: 8px; padding: 10px 20px; font-weight: 700; cursor: pointer; font-family: inherit; font-size: 14px;">+ اضافة</button>
                            </form>
                        </div>
                    </div>
                    <% } %>

                    <div class="form-group">
                        <div class="checkbox-group">
                            <input type="hidden" name="is_active" value="0">
                            <input type="checkbox" name="is_active" id="is_active" value="1" <%= product && product.is_active ? 'checked' : (!product ? 'checked' : '') %>>
                            <label for="is_active">منتج نشط (يظهر في المتجر)</label>
                        </div>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary btn-lg"><%= product ? 'حفظ التعديلات' : 'اضافة المنتج' %></button>
                        <a href="/admin/products" class="btn btn-secondary btn-lg">الغاء</a>
                    </div>
                </form>
            </div>
        </main>
    </div>
    <script>
        function handleMainImagePreview(input) {
            var file = input.files && input.files[0];
            if (!file) return;
            var dropContent = document.getElementById('mainImageDropContent');
            var preview = document.getElementById('mainImagePreview');
            var previewImg = document.getElementById('mainImagePreviewImg');
            var previewName = document.getElementById('mainImagePreviewName');

            if (file.type.startsWith('image/')) {
                var reader = new FileReader();
                reader.onload = function(e) {
                    previewImg.src = e.target.result;
                    previewName.textContent = file.name;
                    dropContent.style.display = 'none';
                    preview.style.display = 'block';
                };
                reader.readAsDataURL(file);
            }
        }

        function clearMainImagePreview() {
            var input = document.getElementById('mainImageInput');
            var dropContent = document.getElementById('mainImageDropContent');
            var preview = document.getElementById('mainImagePreview');
            input.value = '';
            dropContent.style.display = '';
            preview.style.display = 'none';
        }
    </script>
</body>
</html>
