<!DOCTYPE html>
<html lang="<%= typeof lang !== 'undefined' ? lang : 'ar' %>" dir="<%= typeof dir !== 'undefined' ? dir : 'rtl' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= page ? 'تعديل صفحة الهبوط' : 'صفحة هبوط جديدة' %> — لوحة التحكم</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Cairo', sans-serif; background: #f5f1ed; direction: rtl; text-align: right; min-height: 100vh; }
        .admin-wrapper { display: flex; min-height: 100vh; }
        .sidebar { width: 260px; background: #6B5335; color: #fff; position: fixed; top: 0; right: 0; bottom: 0; z-index: 100; display: flex; flex-direction: column; transition: transform 0.3s; overflow-y: auto; }
        .sidebar-header { padding: 28px 24px 20px; border-bottom: 1px solid rgba(255,255,255,0.1); }
        .sidebar-header h2 { font-size: 20px; font-weight: 700; }
        .sidebar-header p { font-size: 12px; opacity: 0.6; margin-top: 2px; }
        .sidebar-nav { list-style: none; padding: 16px 0; flex: 1; }
        .sidebar-nav li a { display: flex; align-items: center; gap: 12px; padding: 12px 24px; color: rgba(255,255,255,0.75); text-decoration: none; font-size: 15px; font-weight: 600; transition: all 0.2s; }
        .sidebar-nav li a:hover, .sidebar-nav li a.active { background: rgba(255,255,255,0.1); color: #fff; }
        .sidebar-nav li a.active { border-left: 3px solid #fff; }
        .sidebar-nav li a svg { width: 20px; height: 20px; fill: currentColor; flex-shrink: 0; }
        .sidebar-divider { height: 1px; background: rgba(255,255,255,0.1); margin: 8px 24px; }
        .sidebar-footer { padding: 16px 24px; border-top: 1px solid rgba(255,255,255,0.1); }
        .sidebar-footer a { display: flex; align-items: center; gap: 12px; color: rgba(255,255,255,0.6); text-decoration: none; font-size: 14px; font-weight: 600; transition: color 0.2s; }
        .sidebar-footer a:hover { color: #fff; }
        .sidebar-footer a svg { width: 20px; height: 20px; fill: currentColor; }
        .main-content { flex: 1; margin-right: 260px; padding: 32px; }
        .page-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 28px; flex-wrap: wrap; gap: 12px; }
        .page-title { font-size: 26px; font-weight: 700; color: #6B5335; }
        .btn { display: inline-block; padding: 10px 24px; border: none; border-radius: 10px; font-family: 'Cairo', sans-serif; font-size: 14px; font-weight: 700; cursor: pointer; text-decoration: none; transition: opacity 0.2s; }
        .btn:hover { opacity: 0.85; }
        .btn-primary { background: #8B6F47; color: #fff; }
        .btn-secondary { background: #e8e0d8; color: #6B5335; }
        .btn-delete { background: #ffebee; color: #c62828; }
        .btn-sm { padding: 6px 14px; font-size: 12px; }
        .btn-lg { padding: 14px 40px; font-size: 16px; }
        .form-card { background: #fff; border-radius: 14px; box-shadow: 0 2px 12px rgba(0,0,0,0.04); padding: 32px; max-width: 900px; margin-bottom: 28px; }
        .form-card h3 { font-size: 18px; color: #6B5335; margin-bottom: 20px; padding-bottom: 12px; border-bottom: 1px solid #f0ebe5; }
        .form-group { margin-bottom: 24px; }
        .form-group label { display: block; font-size: 14px; font-weight: 700; color: #555; margin-bottom: 8px; }
        .form-group input[type="text"], .form-group input[type="file"], .form-group input[type="url"], .form-group textarea, .form-group select {
            width: 100%; padding: 12px 16px; border: 2px solid #e8e0d8; border-radius: 10px;
            font-family: 'Cairo', sans-serif; font-size: 14px; color: #333; transition: border-color 0.2s;
        }
        .form-group input:focus, .form-group textarea:focus, .form-group select:focus { outline: none; border-color: #8B6F47; }
        .form-group textarea { min-height: 100px; resize: vertical; }
        .form-group .hint { font-size: 12px; color: #aaa; margin-top: 6px; }
        .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
        .form-row-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; }
        .checkbox-group { display: flex; align-items: center; gap: 10px; }
        .checkbox-group input[type="checkbox"] { width: 20px; height: 20px; accent-color: #8B6F47; cursor: pointer; }
        .checkbox-group label { margin-bottom: 0; cursor: pointer; font-size: 15px; }
        .form-actions { display: flex; gap: 12px; margin-top: 32px; padding-top: 24px; border-top: 1px solid #f0ebe5; }

        /* Section items - draggable */
        .section-item { background: #faf7f3; border-radius: 12px; padding: 20px; margin-bottom: 12px; border: 2px solid #e8e0d8; cursor: grab; transition: all 0.2s; position: relative; }
        .section-item:hover { border-color: #8B6F47; }
        .section-item.dragging { opacity: 0.4; border-style: dashed; }
        .section-item.drag-over { border-color: #1565c0; background: #e3f2fd; }
        .section-item-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; gap: 12px; }
        .section-type-badge { font-size: 12px; font-weight: 700; color: #fff; padding: 4px 12px; border-radius: 6px; display: inline-flex; align-items: center; gap: 6px; }
        .type-text { background: #6B5335; }
        .type-image { background: #1565c0; }
        .type-video { background: #c62828; }
        .type-button { background: #2e7d32; }
        .type-gif { background: #f57f17; }
        .section-actions { display: flex; gap: 6px; }
        .section-item h4 { font-size: 15px; color: #333; margin-bottom: 4px; }
        .section-item p { font-size: 13px; color: #888; }
        .section-item img { max-width: 200px; max-height: 80px; border-radius: 8px; margin-top: 8px; border: 1px solid #ddd; }
        .drag-handle { cursor: grab; font-size: 18px; color: #aaa; margin-left: 8px; user-select: none; }

        /* Section type selector */
        .section-types { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 20px; }
        .section-type-btn { display: flex; align-items: center; gap: 8px; padding: 10px 18px; border: 2px solid #e8e0d8; border-radius: 10px; background: #fff; cursor: pointer; font-family: inherit; font-size: 14px; font-weight: 600; color: #555; transition: all 0.2s; }
        .section-type-btn:hover { border-color: #8B6F47; color: #8B6F47; }
        .section-type-btn .emoji { font-size: 20px; }

        /* Edit modal */
        .edit-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 1000; align-items: center; justify-content: center; }
        .edit-overlay.active { display: flex; }
        .edit-modal { background: #fff; border-radius: 16px; padding: 32px; width: 90%; max-width: 600px; max-height: 90vh; overflow-y: auto; }
        .edit-modal h3 { font-size: 18px; color: #6B5335; margin-bottom: 20px; }

        .mobile-toggle { display: none; position: fixed; top: 16px; right: 16px; z-index: 200; background: #6B5335; color: #fff; border: none; border-radius: 10px; width: 44px; height: 44px; font-size: 20px; cursor: pointer; }
        .sidebar-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 90; }
        @media (max-width: 768px) {
            .mobile-toggle { display: block; }
            .sidebar { transform: translateX(100%); }
            .sidebar.open { transform: translateX(0); }
            .sidebar-overlay.open { display: block; }
            .main-content { margin-right: 0; padding: 24px 16px; padding-top: 72px; }
            .form-row { grid-template-columns: 1fr; }
            .form-row-3 { grid-template-columns: 1fr; }
            .form-card { padding: 24px 20px; }
            .section-types { gap: 8px; }
            .section-type-btn { padding: 8px 14px; font-size: 13px; }
        }
    </style>
</head>
<body>
    <button class="mobile-toggle" onclick="document.querySelector('.sidebar').classList.toggle('open'); document.querySelector('.sidebar-overlay').classList.toggle('open');">&#9776;</button>
    <div class="sidebar-overlay" onclick="document.querySelector('.sidebar').classList.remove('open'); this.classList.remove('open');"></div>

    <div class="admin-wrapper">
        <aside class="sidebar">
            <div class="sidebar-header"><h2>لوحة التحكم</h2><p>ادارة المتجر</p></div>
            <ul class="sidebar-nav">
                <li><a href="/admin"><svg viewBox="0 0 24 24"><path d="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z"/></svg>الرئيسية</a></li>
                <li><a href="/admin/products"><svg viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 14H4V6h16v12zM6 10h2v2H6zm0 4h8v2H6zm10 0h2v2h-2zm-6-4h8v2h-8z"/></svg>المنتجات</a></li>
                <li><a href="/admin/orders"><svg viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-2 10H7v-2h10v2z"/></svg>الطلبات</a></li>
                <li><a href="/admin/reviews"><svg viewBox="0 0 24 24"><path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H6l-2 2V4h16v12z"/></svg>التعليقات</a></li>
                <div class="sidebar-divider"></div>
                <li><a href="/admin/categories"><svg viewBox="0 0 24 24"><path d="M12 2l-5.5 9h11L12 2zm0 3.84L13.93 9h-3.87L12 5.84zM17.5 13c-2.49 0-4.5 2.01-4.5 4.5s2.01 4.5 4.5 4.5 4.5-2.01 4.5-4.5-2.01-4.5-4.5-4.5zm0 7c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5zM3 21.5h8v-8H3v8zm2-6h4v4H5v-4z"/></svg>التصنيفات</a></li>
                <li><a href="/admin/collections"><svg viewBox="0 0 24 24"><path d="M4 6H2v14c0 1.1.9 2 2 2h14v-2H4V6zm16-4H8c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H8V4h12v12zM10 9h8v2h-8zm0 3h4v2h-4zm0-6h8v2h-8z"/></svg>المجموعات</a></li>
                <li><a href="/admin/landing-pages" class="active"><svg viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14zM7 10h2v7H7zm4-3h2v10h-2zm4 6h2v4h-2z"/></svg>صفحات الهبوط</a></li>
                <li><a href="/admin/pages"><svg viewBox="0 0 24 24"><path d="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zm4 18H6V4h7v5h5v11zM8 15.01V17h1.99l5.88-5.88-1.99-1.99L8 15.01zm7.87-7.87l1.99 1.99.86-.86c.39-.39.39-1.02 0-1.41l-.59-.59c-.39-.39-1.02-.39-1.41 0l-.85.87z"/></svg>الصفحات</a></li>
                <li><a href="/admin/banners"><svg viewBox="0 0 24 24"><path d="M19 5H5c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 12H5V7h14v10zM6 13h2v2H6zm0-4h12v2H6zm4 4h8v2h-8z"/></svg>البانرات</a></li>
                <li><a href="/admin/gifts"><svg viewBox="0 0 24 24"><path d="M20 6h-2.18c.11-.31.18-.65.18-1 0-1.66-1.34-3-3-3-1.05 0-1.96.54-2.5 1.35l-.5.67-.5-.68C10.96 2.54 10.05 2 9 2 7.34 2 6 3.34 6 5c0 .35.07.69.18 1H4c-1.11 0-1.99.89-1.99 2L2 19c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V8c0-1.11-.89-2-2-2zm-5-2c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zM9 4c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm11 15H4v-2h16v2zm0-5H4V8h5.08L7 10.83 8.62 12 11 8.76l1-1.36 1 1.36L15.38 12 17 10.83 14.92 8H20v6z"/></svg>الهدايا</a></li>
                <div class="sidebar-divider"></div>
                <li><a href="/admin/users"><svg viewBox="0 0 24 24"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/></svg>المسوقين</a></li>
                <li><a href="/admin/withdrawals"><svg viewBox="0 0 24 24"><path d="M21 18v1c0 1.1-.9 2-2 2H5c-1.11 0-2-.9-2-2V5c0-1.1.89-2 2-2h14c1.1 0 2 .9 2 2v1h-9c-1.11 0-2 .9-2 2v8c0 1.1.89 2 2 2h9zm-9-2h10V8H12v8zm4-2.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/></svg>طلبات السحب</a></li>
                <div class="sidebar-divider"></div>
                <li><a href="/admin/settings/bank"><svg viewBox="0 0 24 24"><path d="M4 10v7h3v-7H4zm6 0v7h3v-7h-3zM2 22h19v-3H2v3zm14-12v7h3v-7h-3zm-4.5-9L2 6v2h19V6l-9.5-5z"/></svg>التحويل البنكي</a></li>
                <li><a href="/admin/shipping-companies"><svg viewBox="0 0 24 24"><path d="M20 8h-3V4H3c-1.1 0-2 .9-2 2v11h2c0 1.66 1.34 3 3 3s3-1.34 3-3h6c0 1.66 1.34 3 3 3s3-1.34 3-3h2v-5l-3-4zM6 18.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm13.5-9l1.96 2.5H17V9.5h2.5zm-1.5 9c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/></svg>شركات التوصيل</a></li>
                <li><a href="/admin/settings"><svg viewBox="0 0 24 24"><path d="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.07.62-.07.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"/></svg>الاعدادات</a></li>
            </ul>
            <div class="sidebar-footer"><a href="/admin/logout"><svg viewBox="0 0 24 24"><path d="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z"/></svg>تسجيل الخروج</a></div>
        </aside>

        <main class="main-content">
            <div class="page-header">
                <h1 class="page-title"><%= page ? 'تعديل صفحة الهبوط' : 'صفحة هبوط جديدة' %></h1>
                <div style="display: flex; gap: 10px; flex-wrap: wrap;">
                    <% if (page && page.is_published) { %>
                        <a href="/p/<%= page.slug %>" target="_blank" class="btn" style="background: #1565c0; color: #fff;">معاينة الصفحة</a>
                    <% } %>
                    <a href="/admin/landing-pages" class="btn btn-secondary">&#8592; رجوع</a>
                </div>
            </div>

            <!-- Page Settings -->
            <div class="form-card">
                <h3>اعدادات الصفحة</h3>
                <form method="POST" action="<%= page ? '/admin/landing-pages/' + page.id : '/admin/landing-pages' %>">
                    <div class="form-group">
                        <label>العنوان *</label>
                        <input type="text" name="title" value="<%= page ? page.title : '' %>" placeholder="عنوان صفحة الهبوط" required>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>الرابط (slug) *</label>
                            <input type="text" name="slug" value="<%= page ? page.slug : '' %>" placeholder="landing-page-name" required dir="ltr" style="text-align:left;">
                        </div>
                        <div class="form-group">
                            <label>نوع الدفع</label>
                            <select name="payment_type">
                                <option value="bank" <%= page && page.payment_type === 'bank' ? 'selected' : (!page ? 'selected' : '') %>>تحويل بنكي</option>
                                <option value="cod" <%= page && page.payment_type === 'cod' ? 'selected' : '' %>>الدفع عند الاستلام</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>المنتج المرتبط</label>
                        <select name="product_id">
                            <option value="">-- بدون منتج --</option>
                            <% products.forEach(function(p) { %>
                                <option value="<%= p.id %>" <%= page && page.product_id == p.id ? 'selected' : '' %>><%= p.title %></option>
                            <% }); %>
                        </select>
                    </div>

                    <div class="form-group">
                        <div class="checkbox-group">
                            <input type="checkbox" name="is_published" id="is_published" value="1" <%= page && page.is_published ? 'checked' : '' %>>
                            <label for="is_published">منشورة (ظاهرة للعملاء)</label>
                        </div>
                    </div>

                    <div class="form-group">
                        <div class="checkbox-group">
                            <input type="checkbox" name="hide_header" id="hide_header" value="1" <%= page && page.hide_header ? 'checked' : '' %>>
                            <label for="hide_header">إخفاء اسم المتجر / اللوجو (الهيدر)</label>
                        </div>
                        <div class="hint">عند التفعيل، لن يظهر اسم المتجر أو اللوجو في أعلى الصفحة — يمنع الزائر من الرجوع للصفحة الرئيسية</div>
                    </div>

                    <div class="form-group">
                        <div class="checkbox-group">
                            <input type="checkbox" name="show_reviews" id="show_reviews" value="1" <%= page && page.show_reviews ? 'checked' : '' %>>
                            <label for="show_reviews">عرض تعليقات وتقييمات العملاء (Feedback)</label>
                        </div>
                        <div class="hint">عند التفعيل، ستظهر تعليقات العملاء أسفل صفحة الهبوط</div>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary btn-lg"><%= page ? 'حفظ التعديلات' : 'انشاء الصفحة' %></button>
                        <a href="/admin/landing-pages" class="btn btn-secondary btn-lg">الغاء</a>
                    </div>
                </form>
            </div>

            <% if (page) { %>
            <!-- Background Audio Section -->
            <div class="form-card">
                <h3>صوت الخلفية (Background Audio)</h3>
                <form method="POST" action="/admin/landing-pages/<%= page.id %>/bg-audio" enctype="multipart/form-data">
                    <div class="form-group" style="margin-bottom: 14px;">
                        <label>ملف صوت (MP3)</label>
                        <input type="file" name="media" accept="audio/mp3,audio/mpeg,.mp3">
                        <% if (page.bg_audio_filename) { %>
                            <div class="hint" style="color: #2e7d32; margin-top: 8px;">ملف حالي: <%= page.bg_audio_filename %></div>
                        <% } %>
                    </div>
                    <div class="checkbox-group" style="margin-bottom: 16px;">
                        <input type="checkbox" name="bg_audio_enabled" id="bg_audio_enabled" value="1" <%= page.bg_audio_enabled ? 'checked' : '' %>>
                        <label for="bg_audio_enabled">تشغيل الصوت تلقائيا عند دخول الصفحة</label>
                    </div>
                    <button type="submit" class="btn btn-primary">حفظ الصوت</button>
                </form>
            </div>

            <!-- Sections Management -->
            <div class="form-card">
                <h3>اقسام الصفحة <span style="font-size: 13px; color: #aaa; font-weight: 400;">— اسحب لإعادة الترتيب</span></h3>

                <div id="sectionsList">
                <% if (sections && sections.length > 0) { %>
                    <% sections.forEach(function(section, idx) { %>
                        <div class="section-item" draggable="true" data-section-id="<%= section.id %>">
                            <div class="section-item-header">
                                <div style="display: flex; align-items: center; gap: 8px;">
                                    <span class="drag-handle">&#9776;</span>
                                    <span class="section-type-badge type-<%= section.section_type %>">
                                        <%= section.section_type === 'text' ? 'نص' : section.section_type === 'image' ? 'صورة' : section.section_type === 'video' ? 'فيديو' : section.section_type === 'button' ? 'زر' : 'GIF' %>
                                    </span>
                                    <% if (section.full_width) { %><span style="font-size: 11px; background: #e3f2fd; color: #1565c0; padding: 2px 8px; border-radius: 4px;">Full Width</span><% } %>
                                </div>
                                <div class="section-actions">
                                    <button type="button" class="btn btn-sm" style="background:#fff3e0; color:#e65100; padding:4px 10px;" onclick="openEditModal(<%= section.id %>)">تعديل</button>
                                    <form method="POST" action="/admin/landing-pages/<%= page.id %>/section/<%= section.id %>/delete" style="display:inline;" onclick="return confirm('حذف هذا القسم؟')">
                                        <button type="submit" class="btn btn-delete btn-sm">حذف</button>
                                    </form>
                                </div>
                            </div>
                            <% if (section.title) { %><h4><%= section.title %></h4><% } %>
                            <% if (section.content) { %><p><%= section.content.substring(0, 120) %><%= section.content.length > 120 ? '...' : '' %></p><% } %>
                            <% if (section.section_type === 'button') { %>
                                <div style="margin-top: 8px;">
                                    <span style="display: inline-block; padding: 6px 20px; border-radius: 8px; font-size: 13px; font-weight: 700; color: #fff; background: <%= section.button_color || '#8B6F47' %>;"><%= section.title || 'اشترِ الآن' %></span>
                                    <span style="font-size: 11px; color: #888; margin-right: 8px;"><%= section.button_type === 'add_to_cart' ? 'أضف للسلة' : 'اشتري الآن' %> — <%= section.button_size || 'medium' %></span>
                                </div>
                            <% } %>
                            <% if (section.media_filename && (section.section_type === 'image' || section.section_type === 'gif')) { %>
                                <img src="/uploads/landing-pages/<%= section.media_filename %>" alt="">
                            <% } else if (section.media_filename && section.section_type === 'video') { %>
                                <div style="font-size: 12px; color: #1565c0; margin-top: 6px;">ملف فيديو: <%= section.media_filename %></div>
                            <% } %>
                            <% if (section.video_url) { %>
                                <div style="font-size: 12px; color: #c62828; margin-top: 4px;">رابط: <%= section.video_url.substring(0, 60) %>...</div>
                            <% } %>
                        </div>
                    <% }); %>
                <% } else { %>
                    <p style="color:#aaa; text-align:center; padding:30px 0; font-size:14px;">لا توجد اقسام بعد — اختر نوع القسم من الأسفل</p>
                <% } %>
                </div>

                <div id="saveOrderMsg" style="display: none; padding: 12px 20px; background: #e8f5e9; color: #2e7d32; border-radius: 10px; margin-bottom: 16px; font-weight: 600; text-align: center;"></div>

                <!-- Add New Section -->
                <div style="background: #f3f7fa; border-radius: 12px; padding: 24px; margin-top: 20px; border: 2px solid #d8e0e8;">
                    <h4 style="font-size: 16px; color: #335b6b; margin-bottom: 16px;">اضافة قسم جديد</h4>

                    <div class="section-types" id="sectionTypeSelector">
                        <button type="button" class="section-type-btn" onclick="showAddForm('text')"><span class="emoji">📝</span> نص</button>
                        <button type="button" class="section-type-btn" onclick="showAddForm('image')"><span class="emoji">🖼️</span> صورة</button>
                        <button type="button" class="section-type-btn" onclick="showAddForm('video')"><span class="emoji">🎥</span> فيديو</button>
                        <button type="button" class="section-type-btn" onclick="showAddForm('button')"><span class="emoji">🔘</span> زر</button>
                        <button type="button" class="section-type-btn" onclick="showAddForm('gif')"><span class="emoji">✨</span> GIF</button>
                    </div>

                    <!-- Dynamic Add Form -->
                    <form method="POST" action="/admin/landing-pages/<%= page.id %>/section" enctype="multipart/form-data" id="addSectionForm" style="display: none;">
                        <input type="hidden" name="section_type" id="addSectionType">

                        <div class="form-group" style="margin-bottom:14px;">
                            <label id="addTitleLabel">العنوان</label>
                            <input type="text" name="title" id="addTitle" placeholder="عنوان القسم (اختياري)">
                        </div>

                        <div class="form-group" style="margin-bottom:14px;" id="addContentGroup">
                            <label>المحتوى</label>
                            <textarea name="content" id="addContent" placeholder="النص او المحتوى..." style="min-height:80px; resize:vertical;"></textarea>
                        </div>

                        <div class="form-group" style="margin-bottom:14px;" id="addMediaGroup">
                            <label id="addMediaLabel">ملف وسائط</label>
                            <input type="file" name="media" id="addMedia" accept="image/*,video/*">
                        </div>

                        <!-- Video options -->
                        <div id="addVideoOptions" style="display:none;">
                            <div class="form-group" style="margin-bottom:14px;">
                                <label>رابط يوتيوب (اختياري — بدل رفع الملف)</label>
                                <input type="url" name="video_url" placeholder="https://www.youtube.com/watch?v=..." dir="ltr" style="text-align:left;">
                            </div>
                            <div style="display: flex; flex-wrap: wrap; gap: 16px; margin-bottom: 14px;">
                                <div class="checkbox-group"><input type="checkbox" name="autoplay" value="1" id="addAutoplay"><label for="addAutoplay">تشغيل تلقائي</label></div>
                                <div class="checkbox-group"><input type="checkbox" name="muted" value="1" id="addMuted" checked><label for="addMuted">صامت</label></div>
                                <div class="checkbox-group"><input type="checkbox" name="loop_video" value="1" id="addLoop"><label for="addLoop">تكرار</label></div>
                            </div>
                        </div>

                        <!-- Button options -->
                        <div id="addButtonOptions" style="display:none;">
                            <div class="form-row" style="margin-bottom: 14px;">
                                <div class="form-group" style="margin-bottom:0;">
                                    <label>نوع الزر</label>
                                    <select name="button_type">
                                        <option value="buy_now">اشترِ الآن</option>
                                        <option value="add_to_cart">أضف للسلة</option>
                                    </select>
                                </div>
                                <div class="form-group" style="margin-bottom:0;">
                                    <label>حجم الزر</label>
                                    <select name="button_size">
                                        <option value="small">صغير</option>
                                        <option value="medium" selected>متوسط</option>
                                        <option value="large">كبير</option>
                                    </select>
                                </div>
                            </div>
                            <div class="form-group" style="margin-bottom: 14px;">
                                <label>لون الزر</label>
                                <div style="display: flex; align-items: center; gap: 12px;">
                                    <input type="color" name="button_color" value="#8B6F47" style="width: 50px; height: 36px; border: 2px solid #e8e0d8; border-radius: 8px; cursor: pointer; padding: 2px;">
                                </div>
                            </div>
                        </div>

                        <!-- Image options -->
                        <div id="addImageOptions" style="display:none;">
                            <div class="checkbox-group" style="margin-bottom: 14px;">
                                <input type="checkbox" name="full_width" value="1" id="addFullWidth">
                                <label for="addFullWidth">عرض كامل (Full Width — بدون هوامش)</label>
                            </div>
                        </div>

                        <div style="display: flex; gap: 10px;">
                            <button type="submit" class="btn btn-primary">+ اضافة القسم</button>
                            <button type="button" class="btn btn-secondary" onclick="hideAddForm()">الغاء</button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Edit Section Modals -->
            <% if (sections && sections.length > 0) { %>
            <% sections.forEach(function(section) { %>
            <div class="edit-overlay" id="editModal_<%= section.id %>">
                <div class="edit-modal">
                    <h3>تعديل القسم — <%= section.section_type === 'text' ? 'نص' : section.section_type === 'image' ? 'صورة' : section.section_type === 'video' ? 'فيديو' : section.section_type === 'button' ? 'زر' : 'GIF' %></h3>
                    <form method="POST" action="/admin/landing-pages/<%= page.id %>/section/<%= section.id %>/edit" enctype="multipart/form-data">
                        <div class="form-group" style="margin-bottom:14px;">
                            <label><%= section.section_type === 'button' ? 'نص الزر' : 'العنوان' %></label>
                            <input type="text" name="title" value="<%= section.title || '' %>">
                        </div>

                        <% if (section.section_type !== 'button') { %>
                        <div class="form-group" style="margin-bottom:14px;">
                            <label>المحتوى</label>
                            <textarea name="content" style="min-height:80px; resize:vertical;"><%= section.content || '' %></textarea>
                        </div>
                        <% } %>

                        <% if (section.section_type === 'image' || section.section_type === 'gif' || section.section_type === 'video') { %>
                        <div class="form-group" style="margin-bottom:14px;">
                            <label>استبدال الملف (اختياري)</label>
                            <input type="file" name="media" accept="<%= section.section_type === 'video' ? 'video/*' : 'image/*' %>">
                            <% if (section.media_filename) { %>
                                <div class="hint" style="color: #2e7d32;">ملف حالي: <%= section.media_filename %></div>
                            <% } %>
                        </div>
                        <% } %>

                        <% if (section.section_type === 'video') { %>
                        <div class="form-group" style="margin-bottom:14px;">
                            <label>رابط يوتيوب</label>
                            <input type="url" name="video_url" value="<%= section.video_url || '' %>" dir="ltr" style="text-align:left;">
                        </div>
                        <div style="display: flex; flex-wrap: wrap; gap: 16px; margin-bottom: 14px;">
                            <div class="checkbox-group"><input type="checkbox" name="autoplay" value="1" <%= section.autoplay ? 'checked' : '' %>><label>تشغيل تلقائي</label></div>
                            <div class="checkbox-group"><input type="checkbox" name="muted" value="1" <%= section.muted ? 'checked' : '' %>><label>صامت</label></div>
                            <div class="checkbox-group"><input type="checkbox" name="loop_video" value="1" <%= section.loop_video ? 'checked' : '' %>><label>تكرار</label></div>
                        </div>
                        <% } %>

                        <% if (section.section_type === 'button') { %>
                        <div class="form-row" style="margin-bottom: 14px;">
                            <div class="form-group" style="margin-bottom:0;">
                                <label>نوع الزر</label>
                                <select name="button_type">
                                    <option value="buy_now" <%= section.button_type === 'buy_now' ? 'selected' : '' %>>اشترِ الآن</option>
                                    <option value="add_to_cart" <%= section.button_type === 'add_to_cart' ? 'selected' : '' %>>أضف للسلة</option>
                                </select>
                            </div>
                            <div class="form-group" style="margin-bottom:0;">
                                <label>حجم الزر</label>
                                <select name="button_size">
                                    <option value="small" <%= section.button_size === 'small' ? 'selected' : '' %>>صغير</option>
                                    <option value="medium" <%= section.button_size === 'medium' || !section.button_size ? 'selected' : '' %>>متوسط</option>
                                    <option value="large" <%= section.button_size === 'large' ? 'selected' : '' %>>كبير</option>
                                </select>
                            </div>
                        </div>
                        <div class="form-group" style="margin-bottom: 14px;">
                            <label>لون الزر</label>
                            <input type="color" name="button_color" value="<%= section.button_color || '#8B6F47' %>" style="width: 50px; height: 36px; border: 2px solid #e8e0d8; border-radius: 8px; cursor: pointer; padding: 2px;">
                        </div>
                        <% } %>

                        <% if (section.section_type === 'image' || section.section_type === 'gif') { %>
                        <div class="checkbox-group" style="margin-bottom: 14px;">
                            <input type="checkbox" name="full_width" value="1" <%= section.full_width ? 'checked' : '' %>><label>عرض كامل (Full Width)</label>
                        </div>
                        <% } %>

                        <div style="display: flex; gap: 10px;">
                            <button type="submit" class="btn btn-primary">حفظ التعديلات</button>
                            <button type="button" class="btn btn-secondary" onclick="closeEditModal(<%= section.id %>)">الغاء</button>
                        </div>
                    </form>
                </div>
            </div>
            <% }); %>
            <% } %>

            <% } %>
        </main>
    </div>

    <script>
    // === Section Type Add Form ===
    function showAddForm(type) {
        var form = document.getElementById('addSectionForm');
        document.getElementById('addSectionType').value = type;
        form.style.display = 'block';

        // Show/hide fields based on type
        document.getElementById('addContentGroup').style.display = (type === 'button') ? 'none' : '';
        document.getElementById('addMediaGroup').style.display = (type === 'text' || type === 'button') ? 'none' : '';
        document.getElementById('addVideoOptions').style.display = (type === 'video') ? '' : 'none';
        document.getElementById('addButtonOptions').style.display = (type === 'button') ? '' : 'none';
        document.getElementById('addImageOptions').style.display = (type === 'image' || type === 'gif') ? '' : 'none';

        // Update labels
        if (type === 'button') {
            document.getElementById('addTitleLabel').textContent = 'نص الزر';
            document.getElementById('addTitle').placeholder = 'اشترِ الآن';
        } else {
            document.getElementById('addTitleLabel').textContent = 'العنوان';
            document.getElementById('addTitle').placeholder = 'عنوان القسم (اختياري)';
        }

        // Media accept
        var mediaInput = document.getElementById('addMedia');
        if (type === 'video') mediaInput.accept = 'video/*';
        else if (type === 'gif') mediaInput.accept = 'image/gif';
        else mediaInput.accept = 'image/*';
    }

    function hideAddForm() {
        document.getElementById('addSectionForm').style.display = 'none';
    }

    // === Edit Modal ===
    function openEditModal(id) { document.getElementById('editModal_' + id).classList.add('active'); }
    function closeEditModal(id) { document.getElementById('editModal_' + id).classList.remove('active'); }

    // Close modal on overlay click
    document.querySelectorAll('.edit-overlay').forEach(function(overlay) {
        overlay.addEventListener('click', function(e) {
            if (e.target === overlay) overlay.classList.remove('active');
        });
    });

    // === Drag & Drop Reordering ===
    var dragItem = null;
    var sectionsList = document.getElementById('sectionsList');
    if (sectionsList) {
        var items = sectionsList.querySelectorAll('.section-item');
        items.forEach(function(item) {
            item.addEventListener('dragstart', function(e) {
                dragItem = this;
                setTimeout(function() { dragItem.classList.add('dragging'); }, 0);
            });
            item.addEventListener('dragend', function() {
                this.classList.remove('dragging');
                document.querySelectorAll('.section-item').forEach(function(el) { el.classList.remove('drag-over'); });
                dragItem = null;
                saveSectionOrder();
            });
            item.addEventListener('dragover', function(e) {
                e.preventDefault();
                if (this !== dragItem) this.classList.add('drag-over');
            });
            item.addEventListener('dragleave', function() { this.classList.remove('drag-over'); });
            item.addEventListener('drop', function(e) {
                e.preventDefault();
                this.classList.remove('drag-over');
                if (this !== dragItem && dragItem) {
                    var all = Array.from(sectionsList.querySelectorAll('.section-item'));
                    var fromIdx = all.indexOf(dragItem);
                    var toIdx = all.indexOf(this);
                    if (fromIdx < toIdx) {
                        sectionsList.insertBefore(dragItem, this.nextSibling);
                    } else {
                        sectionsList.insertBefore(dragItem, this);
                    }
                }
            });
        });
    }

    function saveSectionOrder() {
        var items = document.querySelectorAll('#sectionsList .section-item');
        var order = [];
        items.forEach(function(item) { order.push(parseInt(item.dataset.sectionId)); });

        var pageId = '<%= page ? page.id : "" %>';
        if (!pageId) return;

        fetch('/admin/landing-pages/' + pageId + '/sections/reorder', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ order: order })
        }).then(function(r) { return r.json(); }).then(function(data) {
            if (data.success) {
                var msg = document.getElementById('saveOrderMsg');
                msg.textContent = 'تم حفظ الترتيب الجديد بنجاح';
                msg.style.display = 'block';
                setTimeout(function() { msg.style.display = 'none'; }, 2500);
            }
        });
    }
    </script>
</body>
</html>
