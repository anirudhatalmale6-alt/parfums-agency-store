                                            <label>صورة موبايل (اختياري)</label>
                                            <input type="file" name="banner_mobile_image" accept="image/*" style="padding: 8px; border: 1px solid #e0e0e0; border-radius: 8px; width: 100%;">
                                            <% if (col.banner_mobile_image) { %>
                                                <div style="margin-top: 8px;"><img src="/uploads/banners/<%= col.banner_mobile_image %>" style="max-width: 150px; border-radius: 6px;"></div>
                                            <% } %>
                                        </div>
                                        <div class="form-group">
                                            <label>Link</label>
                                            <input type="text" name="banner_link_url" value="<%= col.banner_link_url || '' %>" placeholder="https://">
                                            <div class="info-text">Optional</div>
                                        </div>
                                        <input type="hidden" name="display_mode" value="grid">
                                        <input type="hidden" name="grid_columns" value="2">
                                        <input type="hidden" name="grid_product_count" value="4">
                                        <input type="hidden" name="slider_product_count" value="10">

                                    <% } else { %>
                                        <!-- === PRODUCT CATEGORY CARD BODY === -->
                                        <input type="hidden" name="name" value="<%= col.name %>" id="editName-<%= col.id %>">
                                        <div class="form-group">
                                            <label>Product category</label>
                                            <select name="category_id" onchange="updateEditName(this, '<%= col.id %>')">
                                                <option value="">كل المنتجات</option>
                                                <% categories.forEach(function(cat) { %>
                                                    <option value="<%= cat.id %>" <%= col.category_id == cat.id ? 'selected' : '' %>><%= cat.name %></option>
                                                <% }); %>
                                            </select>
                                        </div>
                                        <div class="mode-toggle" id="modeToggle-<%= col.id %>">
                                            <button type="button" class="mode-toggle-btn <%= col.display_mode === 'list' ? 'active' : '' %>" data-mode="list" onclick="setEditMode('<%= col.id %>', 'list')">
                                                <svg viewBox="0 0 24 24"><path d="M3 13h2v-2H3v2zm0 4h2v-2H3v2zm0-8h2V7H3v2zm4 4h14v-2H7v2zm0 4h14v-2H7v2zM7 7v2h14V7H7z"/></svg>
                                                List
                                            </button>
                                            <button type="button" class="mode-toggle-btn <%= (col.display_mode === 'grid' || col.display_mode === 'slider' || col.display_mode === 'both' || !col.display_mode) ? 'active' : '' %>" data-mode="grid" onclick="setEditMode('<%= col.id %>', 'grid')">
                                                <svg viewBox="0 0 24 24"><path d="M4 11h5V5H4v6zm0 7h5v-6H4v6zm6 0h5v-6h-5v6zm6 0h5v-6h-5v6zm-6-7h5V5h-5v6zm6-6v6h5V5h-5z"/></svg>
                                                Grid
                                            </button>
                                        </div>
                                        <input type="hidden" name="display_mode" id="editMode-<%= col.id %>" value="<%= col.display_mode || 'grid' %>">
                                        <div class="feature-count">
                                            <input type="checkbox" id="featureToggle-<%= col.id %>" checked>
                                            <label for="featureToggle-<%= col.id %>">Feature up to</label>
                                            <select name="grid_product_count">
                                                <option value="2" <%= col.grid_product_count == 2 ? 'selected' : '' %>>2</option>
                                                <option value="4" <%= col.grid_product_count == 4 ? 'selected' : '' %>>4</option>
                                                <option value="6" <%= col.grid_product_count == 6 ? 'selected' : '' %>>6</option>
                                                <option value="8" <%= col.grid_product_count == 8 ? 'selected' : '' %>>8</option>
                                                <option value="10" <%= col.grid_product_count == 10 ? 'selected' : '' %>>10</option>
                                                <option value="12" <%= col.grid_product_count == 12 ? 'selected' : '' %>>12</option>
                                            </select>
                                            <label>products</label>
                                        </div>
                                        <input type="hidden" name="grid_columns" value="<%= col.grid_columns || 2 %>">
                                        <input type="hidden" name="slider_product_count" value="<%= col.slider_product_count || 10 %>">
                                        <% if (col.slider_autoplay) { %><input type="hidden" name="slider_autoplay" value="on"><% } %>
                                    <% } %>

                                    <!-- Common fields -->
                                    <div class="form-row" style="margin-top: 12px;">
                                        <div class="form-group">
                                            <label>الترتيب</label>
                                            <input type="number" name="sort_order" value="<%= col.sort_order %>" min="0">
                                        </div>
                                        <div class="form-group" style="display: flex; align-items: center; gap: 16px; padding-top: 22px;">
                                            <div class="checkbox-inline">
                                                <input type="checkbox" name="is_active" id="editActive-<%= col.id %>" <%= col.is_active ? 'checked' : '' %>>
                                                <label for="editActive-<%= col.id %>">مفعّل</label>
                                            </div>
                                            <div class="checkbox-inline">
                                                <input type="checkbox" name="show_title" id="editShowTitle-<%= col.id %>" <%= col.show_title ? 'checked' : '' %>>
                                                <label for="editShowTitle-<%= col.id %>">عرض العنوان</label>
                                            </div>
                                        </div>
