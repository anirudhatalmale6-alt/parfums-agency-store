<!DOCTYPE html>
<html lang="<%= typeof lang !== 'undefined' ? lang : 'ar' %>" dir="<%= typeof dir !== 'undefined' ? dir : 'rtl' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Design — Storefront</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Cairo', sans-serif; background: #f8f8f8; direction: rtl; text-align: right; min-height: 100vh; }
        .admin-wrapper { display: flex; min-height: 100vh; }
        .sidebar { width: 260px; background: #6B5335; color: #fff; position: fixed; top: 0; right: 0; bottom: 0; z-index: 100; display: flex; flex-direction: column; transition: transform 0.3s; overflow-y: auto; }
        .sidebar-header { padding: 28px 24px 20px; border-bottom: 1px solid rgba(255,255,255,0.1); }
        .sidebar-header h2 { font-size: 20px; font-weight: 700; }
        .sidebar-header p { font-size: 12px; opacity: 0.6; margin-top: 2px; }
        .sidebar-nav { list-style: none; padding: 16px 0; flex: 1; }
        .sidebar-nav li a { display: flex; align-items: center; gap: 12px; padding: 12px 24px; color: rgba(255,255,255,0.75); text-decoration: none; font-size: 15px; font-weight: 600; transition: all 0.2s; }
        .sidebar-nav li a:hover, .sidebar-nav li a.active { background: rgba(255,255,255,0.1); color: #fff; }
        .sidebar-nav li a.active { border-left: 3px solid #fff; }
        .sidebar-nav li a svg { width: 20px; height: 20px; fill: currentColor; flex-shrink: 0; }
        .sidebar-divider { height: 1px; background: rgba(255,255,255,0.1); margin: 8px 24px; }
        .sidebar-footer { padding: 16px 24px; border-top: 1px solid rgba(255,255,255,0.1); }
        .sidebar-footer a { display: flex; align-items: center; gap: 12px; color: rgba(255,255,255,0.6); text-decoration: none; font-size: 14px; font-weight: 600; transition: color 0.2s; }
        .sidebar-footer a:hover { color: #fff; }
        .sidebar-footer a svg { width: 20px; height: 20px; fill: currentColor; }
        .main-content { flex: 1; margin-right: 260px; padding: 32px; max-width: 820px; }

        /* Design Panel Header */
        .design-header { margin-bottom: 8px; }
        .design-header h1 { font-size: 24px; font-weight: 700; color: #1a1a1a; }
        .design-tabs { display: flex; gap: 0; border-bottom: 1px solid #e0e0e0; margin-bottom: 28px; }
        .design-tab { padding: 12px 20px; font-size: 14px; font-weight: 600; color: #888; text-decoration: none; border-bottom: 2px solid transparent; transition: all 0.2s; }
        .design-tab:hover { color: #333; }
        .design-tab.active { color: #1a1a1a; border-bottom-color: #1a1a1a; }

        /* Add Card Button */
        .add-card-btn { display: block; width: 100%; padding: 14px; background: #2E2E2E; color: #fff; border: none; border-radius: 10px; font-family: 'Cairo', sans-serif; font-size: 15px; font-weight: 700; cursor: pointer; transition: background 0.2s; margin-bottom: 20px; }
        .add-card-btn:hover { background: #444; }

        /* Section Cards */
        .section-card { background: #fff; border: 1px solid #e8e8e8; border-radius: 12px; margin-bottom: 16px; overflow: hidden; transition: box-shadow 0.2s; }
        .section-card:hover { box-shadow: 0 2px 12px rgba(0,0,0,0.06); }
        .section-card.dragging { opacity: 0.5; box-shadow: 0 4px 20px rgba(0,0,0,0.15); }

        /* Card Header — drag handle + type icon + title */
        .card-header { display: flex; align-items: center; padding: 16px 20px; gap: 12px; cursor: pointer; user-select: none; }
        .drag-handle { cursor: grab; color: #ccc; font-size: 20px; line-height: 1; display: flex; flex-direction: column; gap: 2px; }
        .drag-handle span { display: block; width: 14px; height: 2px; background: #ccc; border-radius: 1px; }
        .card-type-icon { width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; border-radius: 6px; font-size: 14px; flex-shrink: 0; }
        .card-type-icon.products { background: #f0f0f0; color: #555; }
        .card-type-icon.banner { background: #f0f0f0; color: #555; }
        .card-type-label { font-size: 14px; font-weight: 600; color: #555; }
        .card-title { font-size: 15px; font-weight: 700; color: #1a1a1a; flex: 1; }
        .card-actions { display: flex; gap: 8px; align-items: center; margin-right: auto; }
        .card-action-btn { width: 32px; height: 32px; border: none; background: none; cursor: pointer; color: #999; display: flex; align-items: center; justify-content: center; border-radius: 6px; transition: all 0.15s; }
        .card-action-btn:hover { background: #f5f5f5; color: #333; }
        .card-action-btn.danger:hover { background: #ffebee; color: #c62828; }
        .card-action-btn svg { width: 18px; height: 18px; fill: currentColor; }

        /* Card Body — collapsible */
        .card-body { display: none; padding: 0 20px 20px; border-top: 1px solid #f0f0f0; }
        .card-body.open { display: block; padding-top: 20px; }

        /* Form elements */
        .form-group { margin-bottom: 16px; }
        .form-group label { display: block; font-size: 13px; font-weight: 700; color: #555; margin-bottom: 6px; }
        .form-group input[type="text"], .form-group input[type="number"], .form-group select, .form-group input[type="url"] {
            width: 100%; padding: 10px 14px; border: 1px solid #e0e0e0; border-radius: 8px;
            font-family: 'Cairo', sans-serif; font-size: 14px; color: #333; transition: border-color 0.2s; background: #fff;
        }
        .form-group input:focus, .form-group select:focus { outline: none; border-color: #2E2E2E; }
        .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
        .info-text { font-size: 12px; color: #aaa; margin-top: 4px; }

        /* Display mode toggle (List / Grid) */
        .mode-toggle { display: flex; border: 1px solid #e0e0e0; border-radius: 8px; overflow: hidden; margin-bottom: 16px; }
        .mode-toggle-btn { flex: 1; padding: 10px; font-family: 'Cairo', sans-serif; font-size: 13px; font-weight: 600; border: none; background: #fff; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 6px; color: #999; transition: all 0.15s; }
        .mode-toggle-btn:not(:last-child) { border-left: 1px solid #e0e0e0; }
        .mode-toggle-btn.active { background: #f5f5f5; color: #1a1a1a; }
        .mode-toggle-btn svg { width: 16px; height: 16px; fill: currentColor; }

        /* Feature count checkbox */
        .feature-count { display: flex; align-items: center; gap: 10px; padding: 12px 16px; background: #fafafa; border-radius: 8px; margin-bottom: 16px; }
        .feature-count input[type="checkbox"] { width: 18px; height: 18px; accent-color: #2E2E2E; }
        .feature-count label { font-size: 14px; font-weight: 600; color: #333; cursor: pointer; }
        .feature-count select { padding: 4px 8px; border: 1px solid #ddd; border-radius: 6px; font-family: 'Cairo', sans-serif; font-size: 13px; width: auto; }

        /* Image upload zone */
        .upload-zone { border: 2px dashed #ddd; border-radius: 10px; padding: 28px; text-align: center; cursor: pointer; transition: all 0.2s; background: #fafafa; position: relative; }
        .upload-zone:hover { border-color: #aaa; background: #f5f5f5; }
        .upload-zone input[type="file"] { position: absolute; inset: 0; opacity: 0; cursor: pointer; }
        .upload-zone-icon { font-size: 24px; color: #ccc; margin-bottom: 8px; }
        .upload-zone-text { font-size: 14px; color: #666; }
        .upload-zone-text span { color: #2E7D32; font-weight: 600; cursor: pointer; }
        .upload-zone-info { font-size: 12px; color: #aaa; margin-top: 4px; }

        /* Banner preview thumbnail */
        .banner-thumb { display: inline-block; position: relative; margin-top: 10px; }
        .banner-thumb img { max-width: 200px; max-height: 80px; border-radius: 8px; border: 1px solid #e0e0e0; }
        .banner-thumb-remove { position: absolute; top: -6px; right: -6px; width: 20px; height: 20px; background: #c62828; color: #fff; border: none; border-radius: 50%; font-size: 12px; cursor: pointer; display: flex; align-items: center; justify-content: center; }

        /* Checkbox */
        .checkbox-inline { display: flex; align-items: center; gap: 8px; }
        .checkbox-inline input[type="checkbox"] { width: 18px; height: 18px; accent-color: #2E2E2E; }
        .checkbox-inline label { font-size: 13px; color: #666; font-weight: 600; cursor: pointer; }

        /* Save button */
        .btn-save { display: inline-block; padding: 10px 28px; background: #2E2E2E; color: #fff; border: none; border-radius: 8px; font-family: 'Cairo', sans-serif; font-size: 14px; font-weight: 700; cursor: pointer; transition: background 0.2s; }
        .btn-save:hover { background: #444; }

        /* Add card dialog */
        .add-dialog { display: none; background: #fff; border: 1px solid #e0e0e0; border-radius: 12px; margin-bottom: 16px; overflow: hidden; }
        .add-dialog.open { display: block; }
        .add-dialog-header { padding: 16px 20px; border-bottom: 1px solid #f0f0f0; font-size: 16px; font-weight: 700; color: #1a1a1a; display: flex; align-items: center; justify-content: space-between; }
        .add-dialog-body { padding: 20px; }
        .add-dialog-options { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 20px; }
        .add-option { padding: 20px; border: 2px solid #e0e0e0; border-radius: 10px; cursor: pointer; text-align: center; transition: all 0.15s; }
        .add-option:hover { border-color: #aaa; }
        .add-option.selected { border-color: #2E2E2E; background: #fafafa; }
        .add-option-icon { font-size: 28px; margin-bottom: 8px; }
        .add-option-label { font-size: 14px; font-weight: 700; color: #333; }
        .add-option-desc { font-size: 12px; color: #999; margin-top: 4px; }

        /* Empty state */
        .empty-state { padding: 60px 40px; text-align: center; background: #fff; border: 1px solid #e8e8e8; border-radius: 12px; margin-bottom: 16px; }
        .empty-state-icon { font-size: 48px; margin-bottom: 16px; opacity: 0.4; }
        .empty-state p { color: #999; font-size: 14px; }

        .mobile-toggle { display: none; position: fixed; top: 16px; right: 16px; z-index: 200; background: #6B5335; color: #fff; border: none; border-radius: 10px; width: 44px; height: 44px; font-size: 20px; cursor: pointer; }
        .sidebar-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 90; }
        @media (max-width: 768px) {
            .mobile-toggle { display: block; }
            .sidebar { transform: translateX(100%); }
            .sidebar.open { transform: translateX(0); }
            .sidebar-overlay.open { display: block; }
            .main-content { margin-right: 0; padding: 24px 16px; padding-top: 72px; max-width: 100%; }
            .form-row { grid-template-columns: 1fr; }
            .add-dialog-options { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
    <button class="mobile-toggle" onclick="document.querySelector('.sidebar').classList.toggle('open'); document.querySelector('.sidebar-overlay').classList.toggle('open');">&#9776;</button>
    <div class="sidebar-overlay" onclick="document.querySelector('.sidebar').classList.remove('open'); this.classList.remove('open');"></div>

    <div class="admin-wrapper">
        <aside class="sidebar">
            <div class="sidebar-header"><h2>لوحة التحكم</h2><p>ادارة المتجر</p></div>
            <ul class="sidebar-nav">
                <li><a href="/admin"><svg viewBox="0 0 24 24"><path d="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z"/></svg>الرئيسية</a></li>
