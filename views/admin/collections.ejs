                    <% }); %>
                <% } else { %>
                    <div class="empty-state">
                        <div class="empty-state-icon">📦</div>
                        <p>No sections yet</p>
                        <p style="margin-top: 8px;">Click "Add card" to start building your homepage</p>
                    </div>
                <% } %>
            </div>
        </main>
    </div>

    <script>
        // --- Add Dialog ---
        function toggleAddDialog() {
            var d = document.getElementById('addDialog');
            d.classList.toggle('open');
            // Reset
            document.getElementById('addProductForm').style.display = 'none';
            document.getElementById('addBannerForm').style.display = 'none';
            document.getElementById('addFeedbackForm').style.display = 'none';
            document.getElementById('addFaqForm').style.display = 'none';
            document.getElementById('addFooterForm').style.display = 'none';
            document.querySelectorAll('.add-option').forEach(function(o) { o.classList.remove('selected'); });
        }

        function selectAddType(type) {
            document.querySelectorAll('.add-option').forEach(function(o) { o.classList.remove('selected'); });
            document.getElementById('opt-' + type).classList.add('selected');
            document.getElementById('addProductForm').style.display = (type === 'products') ? 'block' : 'none';
            document.getElementById('addBannerForm').style.display = (type === 'banner') ? 'block' : 'none';
            document.getElementById('addFeedbackForm').style.display = (type === 'feedback') ? 'block' : 'none';
            document.getElementById('addFaqForm').style.display = (type === 'faq') ? 'block' : 'none';
            document.getElementById('addFooterForm').style.display = (type === 'footer') ? 'block' : 'none';
        }

        // Auto-set name from category for product sections
        document.querySelector('#addProductForm select[name="category_id"]').addEventListener('change', function() {
            var opt = this.options[this.selectedIndex];
            document.getElementById('newProductName').value = opt.text;
        });

        // --- Mode Toggle (New) ---
        function setNewMode(mode) {
            document.getElementById('newModeVal').value = mode;
            var btns = document.querySelectorAll('#newModeToggle .mode-toggle-btn');
            btns.forEach(function(b) { b.classList.toggle('active', b.dataset.mode === mode); });
        }

        // --- Mode Toggle (Edit) ---
        function setEditMode(id, mode) {
            document.getElementById('editMode-' + id).value = mode;
            var btns = document.querySelectorAll('#modeToggle-' + id + ' .mode-toggle-btn');
            btns.forEach(function(b) { b.classList.toggle('active', b.dataset.mode === mode); });
        }

        // Update name hidden field when category changes
        function updateEditName(select, id) {
            var opt = select.options[select.selectedIndex];
            document.getElementById('editName-' + id).value = opt.text || 'كل المنتجات';
        }

        // --- Card Toggle ---
        function toggleCard(header) {
            var body = header.nextElementSibling;
            body.classList.toggle('open');
        }

        // --- Upload Preview ---
        function previewUpload(input, previewId, zoneId) {
            var preview = document.getElementById(previewId);
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function(e) {
                    preview.innerHTML = '<img src="' + e.target.result + '" style="max-width: 200px; max-height: 100px; border-radius: 8px; border: 1px solid #e0e0e0;">';
                    preview.style.display = 'block';
                };
                reader.readAsDataURL(input.files[0]);
            }
        }

        // --- Drag & Drop Reorder ---
        var dragEl = null;
        document.querySelectorAll('.section-card').forEach(function(card) {
            card.addEventListener('dragstart', function(e) {
                dragEl = this;
                this.classList.add('dragging');
                e.dataTransfer.effectAllowed = 'move';
            });
            card.addEventListener('dragend', function() {
                this.classList.remove('dragging');
                dragEl = null;
                saveOrder();
            });
            card.addEventListener('dragover', function(e) {
                e.preventDefault();
                e.dataTransfer.dropEffect = 'move';
                var container = document.getElementById('sectionsContainer');
                var afterElement = getDragAfterElement(container, e.clientY);
                if (afterElement == null) {
                    container.appendChild(dragEl);
                } else {
                    container.insertBefore(dragEl, afterElement);
                }
            });
        });

        function getDragAfterElement(container, y) {
            var elements = [].slice.call(container.querySelectorAll('.section-card:not(.dragging)'));
            var closest = null;
            var closestOffset = Number.NEGATIVE_INFINITY;
            elements.forEach(function(child) {
                var box = child.getBoundingClientRect();
                var offset = y - box.top - box.height / 2;
                if (offset < 0 && offset > closestOffset) {
                    closestOffset = offset;
                    closest = child;
                }
            });
            return closest;
        }

        function saveOrder() {
            var cards = document.querySelectorAll('.section-card');
            var order = [];
            cards.forEach(function(c) { order.push(parseInt(c.dataset.id)); });
            fetch('/admin/collections/reorder', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ order: order })
            });
        }

        // --- FAQ CRUD ---
        function showAddFaqForm(colId) {
            var form = document.getElementById('addFaqForm-' + colId);
            form.style.display = 'block';
            document.getElementById('faqQ-' + colId).value = '';
            document.getElementById('faqA-' + colId).value = '';
            document.getElementById('faqQfr-' + colId).value = '';
            document.getElementById('faqAfr-' + colId).value = '';
            document.getElementById('faqEditId-' + colId).value = '';
            document.getElementById('faqQ-' + colId).focus();
        }

        function saveFaqItem(colId) {
            var q = document.getElementById('faqQ-' + colId).value.trim();
            var a = document.getElementById('faqA-' + colId).value.trim();
            var qFr = document.getElementById('faqQfr-' + colId).value.trim();
            var aFr = document.getElementById('faqAfr-' + colId).value.trim();
            var editId = document.getElementById('faqEditId-' + colId).value;
            if (!q || !a) { alert('يرجى ملء السؤال والجواب بالعربية على الأقل'); return; }
            var url = editId ? '/admin/collections/' + colId + '/faq/' + editId : '/admin/collections/' + colId + '/faq';
            var method = editId ? 'PUT' : 'POST';
            fetch(url, {
                method: method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ question: q, answer: a, question_fr: qFr, answer_fr: aFr })
            }).then(function(res) { return res.json(); }).then(function(data) {
                if (data.success) location.reload();
                else alert(data.error || 'حدث خطأ');
            }).catch(function() { alert('حدث خطأ في الاتصال'); });
        }

        function editFaqItem(colId, faqId, btn) {
            // Fetch full data from server
            fetch('/admin/collections/' + colId + '/faq/' + faqId).then(function(r) { return r.json(); }).then(function(data) {
                var form = document.getElementById('addFaqForm-' + colId);
                form.style.display = 'block';
                document.getElementById('faqQ-' + colId).value = data.question || '';
                document.getElementById('faqA-' + colId).value = data.answer || '';
                document.getElementById('faqQfr-' + colId).value = data.question_fr || '';
                document.getElementById('faqAfr-' + colId).value = data.answer_fr || '';
                document.getElementById('faqEditId-' + colId).value = faqId;
                document.getElementById('faqQ-' + colId).focus();
            });
        }

        function deleteFaqItem(colId, faqId) {
            if (!confirm('حذف هذا السؤال؟')) return;
            fetch('/admin/collections/' + colId + '/faq/' + faqId, {
                method: 'DELETE'
            }).then(function(res) { return res.json(); }).then(function(data) {
                if (data.success) location.reload();
                else alert(data.error || 'حدث خطأ');
            }).catch(function() { alert('حدث خطأ في الاتصال'); });
        }

        // --- Footer CRUD ---
        function showAddFooterColForm(colId) {
            var form = document.getElementById('addFooterColForm-' + colId);
            form.style.display = 'block';
            document.getElementById('footerColTitle-' + colId).value = '';
            document.getElementById('footerColTitleFr-' + colId).value = '';
            document.getElementById('footerColEditId-' + colId).value = '';
            document.getElementById('footerColTitle-' + colId).focus();
        }

        function editFooterCol(colId, fcId, title, titleFr) {
            var form = document.getElementById('addFooterColForm-' + colId);
            form.style.display = 'block';
            document.getElementById('footerColTitle-' + colId).value = title;
            document.getElementById('footerColTitleFr-' + colId).value = titleFr;
            document.getElementById('footerColEditId-' + colId).value = fcId;
            document.getElementById('footerColTitle-' + colId).focus();
        }

        function saveFooterCol(colId) {
            var title = document.getElementById('footerColTitle-' + colId).value.trim();
            var titleFr = document.getElementById('footerColTitleFr-' + colId).value.trim();
            var editId = document.getElementById('footerColEditId-' + colId).value;
            if (!title) { alert('يرجى إدخال عنوان العمود'); return; }
            var url = editId ? '/admin/collections/' + colId + '/footer-column/' + editId : '/admin/collections/' + colId + '/footer-column';
            var method = editId ? 'PUT' : 'POST';
            fetch(url, {
                method: method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ title: title, title_fr: titleFr })
            }).then(function(r) { return r.json(); }).then(function(data) {
                if (data.success) location.reload();
                else alert(data.error || 'حدث خطأ');
            });
        }

        function deleteFooterCol(colId, fcId) {
            if (!confirm('حذف هذا العمود وجميع روابطه؟')) return;
            fetch('/admin/collections/' + colId + '/footer-column/' + fcId, {
                method: 'DELETE'
            }).then(function(r) { return r.json(); }).then(function(data) {
                if (data.success) location.reload();
                else alert(data.error || 'حدث خطأ');
            });
        }

        function showAddLinkForm(colId, fcId) {
            var form = document.getElementById('addFooterLinkForm-' + colId);
            form.style.display = 'block';
            document.getElementById('footerLinkLabel-' + colId).value = '';
            document.getElementById('footerLinkLabelFr-' + colId).value = '';
            document.getElementById('footerLinkUrl-' + colId).value = '';
            document.getElementById('footerLinkEditId-' + colId).value = '';
            document.getElementById('footerLinkColId-' + colId).value = fcId;
            document.getElementById('footerLinkLabel-' + colId).focus();
        }

        function editFooterLink(colId, linkId, label, labelFr, url) {
            var form = document.getElementById('addFooterLinkForm-' + colId);
            form.style.display = 'block';
            document.getElementById('footerLinkLabel-' + colId).value = label;
            document.getElementById('footerLinkLabelFr-' + colId).value = labelFr;
            document.getElementById('footerLinkUrl-' + colId).value = url;
            document.getElementById('footerLinkEditId-' + colId).value = linkId;
            document.getElementById('footerLinkColId-' + colId).value = '';
            document.getElementById('footerLinkLabel-' + colId).focus();
        }

        function saveFooterLink(colId) {
            var label = document.getElementById('footerLinkLabel-' + colId).value.trim();
            var labelFr = document.getElementById('footerLinkLabelFr-' + colId).value.trim();
            var url = document.getElementById('footerLinkUrl-' + colId).value.trim();
            var editId = document.getElementById('footerLinkEditId-' + colId).value;
            var fcId = document.getElementById('footerLinkColId-' + colId).value;
            if (!label) { alert('يرجى إدخال اسم الرابط'); return; }
            var fetchUrl, method;
            if (editId) {
                fetchUrl = '/admin/collections/' + colId + '/footer-link/' + editId;
                method = 'PUT';
            } else {
                fetchUrl = '/admin/collections/' + colId + '/footer-column/' + fcId + '/link';
                method = 'POST';
            }
            fetch(fetchUrl, {
                method: method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ label: label, label_fr: labelFr, url: url || '#' })
            }).then(function(r) { return r.json(); }).then(function(data) {
                if (data.success) location.reload();
                else alert(data.error || 'حدث خطأ');
            });
        }

        function deleteFooterLink(colId, linkId) {
            if (!confirm('حذف هذا الرابط؟')) return;
            fetch('/admin/collections/' + colId + '/footer-link/' + linkId, {
                method: 'DELETE'
            }).then(function(r) { return r.json(); }).then(function(data) {
                if (data.success) location.reload();
                else alert(data.error || 'حدث خطأ');
            });
        }

        // Footer Icon Management
        function showAddFooterIconForm(colId) {
            document.getElementById('addFooterIconForm-' + colId).style.display = 'block';
            document.getElementById('footerIconName-' + colId).value = '';
            document.getElementById('footerIconUrl-' + colId).value = '';
            document.getElementById('footerIconFile-' + colId).value = '';
            document.getElementById('footerIconEditId-' + colId).value = '';
        }
        function editFooterIcon(colId, iconId, name, url) {
            document.getElementById('addFooterIconForm-' + colId).style.display = 'block';
            document.getElementById('footerIconName-' + colId).value = name;
            document.getElementById('footerIconUrl-' + colId).value = url;
            document.getElementById('footerIconFile-' + colId).value = '';
            document.getElementById('footerIconEditId-' + colId).value = iconId;
        }
        function saveFooterIcon(colId) {
            var editId = document.getElementById('footerIconEditId-' + colId).value;
            var name = document.getElementById('footerIconName-' + colId).value;
            var url = document.getElementById('footerIconUrl-' + colId).value;
            var fileInput = document.getElementById('footerIconFile-' + colId);
            var formData = new FormData();
            formData.append('name', name);
            formData.append('url', url);
            if (fileInput.files[0]) formData.append('icon_image', fileInput.files[0]);
            else if (!editId) { alert('يرجى اختيار صورة'); return; }
            var endpoint = editId
                ? '/admin/collections/' + colId + '/footer-icon/' + editId + '/update'
                : '/admin/collections/' + colId + '/footer-icon';
            fetch(endpoint, { method: 'POST', body: formData })
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (data.success) location.reload();
                    else alert(data.error || 'حدث خطأ');
                });
        }
        function deleteFooterIcon(colId, iconId) {
            if (!confirm('حذف هذه الأيقونة؟')) return;
            fetch('/admin/collections/' + colId + '/footer-icon/' + iconId, { method: 'DELETE' })
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (data.success) location.reload();
                    else alert(data.error || 'حدث خطأ');
                });
        }

        // Color picker sync
        document.querySelectorAll('[id^="footerBgColor-"]').forEach(function(el) {
            if (el.type === 'color') {
                el.addEventListener('input', function() {
                    var id = el.id.replace('footerBgColor-', 'footerBgColorText-');
                    document.getElementById(id).value = el.value;
                });
            }
        });
        document.querySelectorAll('[id^="footerTextColor-"]').forEach(function(el) {
            if (el.type === 'color') {
                el.addEventListener('input', function() {
                    var id = el.id.replace('footerTextColor-', 'footerTextColorText-');
                    document.getElementById(id).value = el.value;
                });
            }
        });

        function saveFooterSettings(colId) {
            var bgColor = document.getElementById('footerBgColorText-' + colId) ? document.getElementById('footerBgColorText-' + colId).value : '#FFFFFF';
            var textColor = document.getElementById('footerTextColorText-' + colId) ? document.getElementById('footerTextColorText-' + colId).value : '#000000';
            fetch('/admin/collections/' + colId + '/footer-settings', {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    footer_description: document.getElementById('footerDesc-' + colId).value,
                    footer_description_fr: document.getElementById('footerDescFr-' + colId).value,
                    footer_copyright: document.getElementById('footerCopy-' + colId).value,
                    footer_copyright_fr: document.getElementById('footerCopyFr-' + colId).value,
                    footer_payment_icons: '',
                    footer_bg_color: bgColor,
                    footer_text_color: textColor,
                    footer_heading_size: document.getElementById('footerHeadingSize-' + colId) ? document.getElementById('footerHeadingSize-' + colId).value : '14',
                    footer_heading_color: document.getElementById('footerHeadingColor-' + colId) ? document.getElementById('footerHeadingColor-' + colId).value : '',
                    footer_link_size: document.getElementById('footerLinkSize-' + colId) ? document.getElementById('footerLinkSize-' + colId).value : '14',
                    footer_link_color: document.getElementById('footerLinkColor-' + colId) ? document.getElementById('footerLinkColor-' + colId).value : '',
                    footer_desc_size: document.getElementById('footerDescSize-' + colId) ? document.getElementById('footerDescSize-' + colId).value : '14',
                    footer_desc_color: document.getElementById('footerDescColor-' + colId) ? document.getElementById('footerDescColor-' + colId).value : ''
                })
            }).then(function(r) { return r.json(); }).then(function(data) {
                if (data.success) {
                    alert('تم حفظ إعدادات الفوتر بنجاح');
                } else {
                    alert(data.error || 'حدث خطأ');
                }
            });
        }

        // Footer Logo Upload
        function uploadFooterLogo(colId) {
            var fileInput = document.getElementById('footerLogoFile-' + colId);
            if (!fileInput.files[0]) return;
            var formData = new FormData();
            formData.append('footer_logo', fileInput.files[0]);
            fetch('/admin/footer-logo-upload', { method: 'POST', body: formData })
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (data.success) location.reload();
                    else alert(data.error || 'حدث خطأ');
                });
        }
        function deleteFooterLogo(colId) {
            if (!confirm('حذف لوجو الفوتر؟')) return;
            fetch('/admin/footer-logo', { method: 'DELETE' })
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (data.success) location.reload();
                    else alert(data.error || 'حدث خطأ');
                });
        }

        // Typography color picker sync
        document.querySelectorAll('[id^="footerHeadingColorPick-"]').forEach(function(el) {
            el.addEventListener('input', function() {
                var id = el.id.replace('footerHeadingColorPick-', 'footerHeadingColor-');
                document.getElementById(id).value = el.value;
            });
        });
        document.querySelectorAll('[id^="footerLinkColorPick-"]').forEach(function(el) {
            el.addEventListener('input', function() {
                var id = el.id.replace('footerLinkColorPick-', 'footerLinkColor-');
                document.getElementById(id).value = el.value;
            });
        });
        document.querySelectorAll('[id^="footerDescColorPick-"]').forEach(function(el) {
            el.addEventListener('input', function() {
                var id = el.id.replace('footerDescColorPick-', 'footerDescColor-');
                document.getElementById(id).value = el.value;
            });
        });

        // Announcement Bar
        function saveAnnouncementSettings() {
            var enabled = document.getElementById('announcementEnabled').checked ? '1' : '0';
            fetch('/admin/announcement-settings', {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    announcement_enabled: enabled,
                    announcement_text: document.getElementById('announcementText').value,
                    announcement_text_fr: document.getElementById('announcementTextFr').value,
                    announcement_bg_color: document.getElementById('announcementBgColor').value,
                    announcement_text_color: document.getElementById('announcementTextColor').value,
                    announcement_height: document.getElementById('announcementHeight').value,
                    announcement_mobile_height: document.getElementById('announcementMobileHeight').value,
                    announcement_link: document.getElementById('announcementLink').value
                })
            }).then(function(r) { return r.json(); }).then(function(data) {
                if (data.success) alert('تم حفظ إعدادات الإعلان بنجاح');
                else alert(data.error || 'حدث خطأ');
            });
        }
    </script>
</body>
