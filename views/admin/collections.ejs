                                                </div>
                                                <div style="flex: 1; min-width: 120px;">
                                                    <label style="font-size: 12px; color: #777; display: block; margin-bottom: 4px;">لون الوصف (فارغ = يرث)</label>
                                                    <div style="display: flex; gap: 6px; align-items: center;">
                                                        <input type="color" id="footerDescColorPick-<%= col.id %>" value="<%= (typeof footerDescColor !== 'undefined' && footerDescColor) || '#000000' %>" style="width: 36px; height: 32px; border: 1px solid #ddd; border-radius: 6px; cursor: pointer; padding: 2px;">
                                                        <input type="text" id="footerDescColor-<%= col.id %>" value="<%= typeof footerDescColor !== 'undefined' ? footerDescColor : '' %>" placeholder="فارغ" style="flex: 1; padding: 8px 10px; border: 1px solid #ddd; border-radius: 8px; font-size: 13px; font-family: monospace;" dir="ltr">
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Footer Logo -->
                                        <div style="margin-bottom: 20px;">
                                            <div style="background: #fce4ec; padding: 8px 12px; border-radius: 6px; margin-bottom: 10px; font-size: 12px; font-weight: 700; color: #c62828;">لوجو الفوتر</div>
                                            <p style="font-size: 12px; color: #999; margin: 0 0 8px;">لوجو خاص بالفوتر (اختياري). إذا فارغ، يستخدم لوجو الموقع الرئيسي. الموضع يتبع اتجاه اللغة تلقائياً.</p>
                                            <div id="footerLogoPreview-<%= col.id %>" style="margin-bottom: 10px;">
                                                <% if (typeof footerLogo !== 'undefined' && footerLogo) { %>
                                                    <div style="display: flex; align-items: center; gap: 12px; padding: 10px; background: #f9f9f9; border: 1px solid #e0e0e0; border-radius: 8px;">
                                                        <img src="/uploads/settings/<%= footerLogo %>" alt="Footer Logo" style="max-height: 40px; max-width: 160px;">
                                                        <button type="button" onclick="deleteFooterLogo(<%= col.id %>)" style="background: none; border: none; cursor: pointer; color: #c62828; font-size: 18px;" title="حذف اللوجو">🗑️</button>
                                                    </div>
                                                <% } %>
                                            </div>
                                            <input type="file" id="footerLogoFile-<%= col.id %>" accept="image/*" style="font-size: 12px;" onchange="uploadFooterLogo(<%= col.id %>)">
                                        </div>

                                        <!-- Copyright AR/FR -->
                                        <div style="margin-bottom: 16px;">
                                            <div class="form-group" style="margin-bottom: 8px;">
                                                <label>Copyright (عربي)</label>
                                                <input type="text" id="footerCopy-<%= col.id %>" value="<%= col.footer_copyright || '' %>" placeholder="© 2026 متجرنا. جميع الحقوق محفوظة." dir="rtl">
                                            </div>
                                            <div class="form-group">
                                                <label>Copyright (FR)</label>
                                                <input type="text" id="footerCopyFr-<%= col.id %>" value="<%= col.footer_copyright_fr || '' %>" placeholder="© 2026 Store. All rights reserved." dir="ltr">
                                            </div>
                                        </div>

                                        <button type="button" onclick="saveFooterSettings(<%= col.id %>)" class="btn-save" style="width: 100%; margin-bottom: 12px;">حفظ إعدادات الفوتر</button>

                                    <% } else if (col.section_type === 'banner') { %>
                                        <!-- === BANNER CARD BODY === -->
                                        <div class="form-group">
                                            <label>Title</label>
                                            <input type="text" name="name" value="<%= col.name %>" placeholder="Title">
                                        </div>
                                        <% if (col.banner_desktop_image) { %>
                                            <div class="banner-thumb" style="margin-bottom: 12px;">
                                                <img src="/uploads/banners/<%= col.banner_desktop_image %>" style="max-width: 100%; max-height: 120px; border-radius: 8px;">
                                                <div class="info-text">Drag to change order</div>
                                            </div>
                                        <% } %>
                                        <div class="upload-zone" id="uploadZone-<%= col.id %>">
                                            <input type="file" name="banner_desktop_image" accept="image/*" onchange="previewUpload(this, 'uploadPreview-<%= col.id %>', 'uploadZone-<%= col.id %>')">
                                            <div class="upload-zone-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="#ccc"><path d="M22 16V4c0-1.1-.9-2-2-2H8c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2zm-11-4l2.03 2.71L16 11l4 5H8l3-4zM2 6v14c0 1.1.9 2 2 2h14v-2H4V6H2z"/></svg></div>
                                            <div class="upload-zone-text">Drag a file here or <span>click to select one</span></div>
                                            <div class="upload-zone-info">File should not exceed 10mb. Recommended ratio is 1:1.</div>
                                        </div>
                                        <div id="uploadPreview-<%= col.id %>" style="margin: 10px 0; display: none;"></div>
