<!DOCTYPE html>
<html lang="<%= typeof lang !== 'undefined' ? lang : 'ar' %>" dir="<%= typeof dir !== 'undefined' ? dir : 'rtl' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= page ? 'تعديل الصفحة' : 'إنشاء صفحة جديدة' %></title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet">
    <script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
    <style>
        .ql-container { font-family: 'Cairo', sans-serif; font-size: 15px; }
        .ql-editor { min-height: 350px; direction: rtl; text-align: right; }
        .ql-editor.ltr { direction: ltr; text-align: left; }
        .ql-toolbar.ql-snow { border-radius: 10px 10px 0 0; border-color: #e0dbd4; background: #faf8f5; }
        .ql-container.ql-snow { border-radius: 0 0 10px 10px; border-color: #e0dbd4; background: #fff; }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Cairo', sans-serif; background: #f5f1ed; direction: rtl; text-align: right; min-height: 100vh; }
        .admin-wrapper { display: flex; min-height: 100vh; }
        .sidebar { width: 260px; background: #6B5335; color: #fff; position: fixed; top: 0; right: 0; bottom: 0; z-index: 100; display: flex; flex-direction: column; transition: transform 0.3s; overflow-y: auto; }
        .sidebar-divider { height: 1px; background: rgba(255,255,255,0.1); margin: 8px 24px; }
        .sidebar-header { padding: 28px 24px 20px; border-bottom: 1px solid rgba(255,255,255,0.1); }
        .sidebar-header h2 { font-size: 20px; font-weight: 700; }
        .sidebar-header p { font-size: 12px; opacity: 0.6; margin-top: 2px; }
        .sidebar-nav { list-style: none; padding: 16px 0; flex: 1; }
        .sidebar-nav li a { display: flex; align-items: center; gap: 12px; padding: 12px 24px; color: rgba(255,255,255,0.75); text-decoration: none; font-size: 15px; font-weight: 600; transition: all 0.2s; }
        .sidebar-nav li a:hover, .sidebar-nav li a.active { background: rgba(255,255,255,0.1); color: #fff; }
        .sidebar-nav li a.active { border-left: 3px solid #fff; }
        .sidebar-nav li a svg { width: 20px; height: 20px; fill: currentColor; flex-shrink: 0; }
        .sidebar-footer { padding: 16px 24px; border-top: 1px solid rgba(255,255,255,0.1); }
        .sidebar-footer a { display: flex; align-items: center; gap: 12px; color: rgba(255,255,255,0.6); text-decoration: none; font-size: 14px; font-weight: 600; transition: color 0.2s; }
        .sidebar-footer a:hover { color: #fff; }
        .sidebar-footer a svg { width: 20px; height: 20px; fill: currentColor; }
        .main-content { flex: 1; margin-right: 260px; padding: 32px; }
        .page-title { font-size: 26px; font-weight: 700; color: #6B5335; margin-bottom: 28px; display: flex; align-items: center; gap: 16px; }
        .page-title a { font-size: 14px; color: #6B5335; text-decoration: none; opacity: 0.7; }
        .page-title a:hover { opacity: 1; }
        .section { background: #fff; border-radius: 14px; box-shadow: 0 2px 12px rgba(0,0,0,0.04); margin-bottom: 28px; padding: 28px; }
        .section h3 { font-size: 17px; font-weight: 700; color: #333; margin-bottom: 20px; padding-bottom: 12px; border-bottom: 1px solid #f0ebe5; }
        .form-group { margin-bottom: 20px; }
        .form-group label { display: block; font-size: 14px; font-weight: 700; color: #555; margin-bottom: 6px; }
        .form-group label small { font-weight: 400; color: #999; }
        .form-control { width: 100%; padding: 10px 14px; border: 1.5px solid #e0dbd4; border-radius: 10px; font-size: 14px; font-family: 'Cairo', sans-serif; background: #faf8f5; transition: border-color 0.2s; direction: rtl; }
        .form-control:focus { outline: none; border-color: #6B5335; background: #fff; }
        .form-control-ltr { direction: ltr; text-align: left; }
        textarea.form-control { min-height: 100px; resize: vertical; }
        .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
        .form-row-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; }
        .btn { display: inline-flex; align-items: center; gap: 8px; padding: 10px 24px; border-radius: 10px; font-size: 14px; font-weight: 700; cursor: pointer; border: none; text-decoration: none; font-family: 'Cairo', sans-serif; transition: all 0.2s; }
        .btn-primary { background: #6B5335; color: #fff; }
        .btn-primary:hover { background: #8B6F47; }
        .btn-outline { background: transparent; border: 1.5px solid #6B5335; color: #6B5335; }
        .btn-outline:hover { background: #6B5335; color: #fff; }
        .form-actions { display: flex; gap: 12px; margin-top: 28px; }
        .slug-preview { font-size: 13px; color: #999; margin-top: 4px; direction: ltr; text-align: left; }
        .tab-nav { display: flex; gap: 0; margin-bottom: 20px; border-bottom: 2px solid #f0ebe5; }
        .tab-btn { padding: 10px 20px; font-size: 14px; font-weight: 700; color: #999; cursor: pointer; border: none; background: none; font-family: 'Cairo', sans-serif; border-bottom: 2px solid transparent; margin-bottom: -2px; transition: all 0.2s; }
        .tab-btn.active { color: #6B5335; border-bottom-color: #6B5335; }
        .tab-content { display: none; }
        .tab-content.active { display: block; }
        .checkbox-group { display: flex; align-items: center; gap: 10px; }
        .checkbox-group input[type="checkbox"] { width: 18px; height: 18px; accent-color: #6B5335; }
        @media (max-width: 768px) {
            .sidebar { transform: translateX(100%); }
            .main-content { margin-right: 0; padding: 20px; }
            .form-row, .form-row-3 { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
    <div class="admin-wrapper">
        <aside class="sidebar">
            <div class="sidebar-header">
                <h2>لوحة التحكم</h2>
                <p>ادارة المتجر</p>
            </div>
            <ul class="sidebar-nav">
                <li><a href="/admin"><svg viewBox="0 0 24 24"><path d="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z"/></svg>الرئيسية</a></li>
                <li><a href="/admin/products"><svg viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 14H4V6h16v12zM6 10h2v2H6zm0 4h8v2H6zm10 0h2v2h-2zm-6-4h8v2h-8z"/></svg>المنتجات</a></li>
                <li><a href="/admin/orders"><svg viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-2 10H7v-2h10v2z"/></svg>الطلبات</a></li>
                <li><a href="/admin/reviews"><svg viewBox="0 0 24 24"><path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H6l-2 2V4h16v12z"/></svg>التعليقات</a></li>
                <div class="sidebar-divider"></div>
                <li><a href="/admin/categories"><svg viewBox="0 0 24 24"><path d="M12 2l-5.5 9h11L12 2zm0 3.84L13.93 9h-3.87L12 5.84zM17.5 13c-2.49 0-4.5 2.01-4.5 4.5s2.01 4.5 4.5 4.5 4.5-2.01 4.5-4.5-2.01-4.5-4.5-4.5zm0 7c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5zM3 21.5h8v-8H3v8zm2-6h4v4H5v-4z"/></svg>التصنيفات</a></li>
                <li><a href="/admin/collections"><svg viewBox="0 0 24 24"><path d="M4 6H2v14c0 1.1.9 2 2 2h14v-2H4V6zm16-4H8c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H8V4h12v12zM10 9h8v2h-8zm0 3h4v2h-4zm0-6h8v2h-8z"/></svg>المجموعات</a></li>
                <li><a href="/admin/landing-pages"><svg viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14zM7 10h2v7H7zm4-3h2v10h-2zm4 6h2v4h-2z"/></svg>صفحات الهبوط</a></li>
                <li><a href="/admin/pages" class="active"><svg viewBox="0 0 24 24"><path d="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zm4 18H6V4h7v5h5v11zM8 15.01V17h1.99l5.88-5.88-1.99-1.99L8 15.01zm7.87-7.87l1.99 1.99.86-.86c.39-.39.39-1.02 0-1.41l-.59-.59c-.39-.39-1.02-.39-1.41 0l-.85.87z"/></svg>الصفحات</a></li>
                <li><a href="/admin/banners"><svg viewBox="0 0 24 24"><path d="M19 5H5c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 12H5V7h14v10zM6 13h2v2H6zm0-4h12v2H6zm4 4h8v2h-8z"/></svg>البانرات</a></li>
                <li><a href="/admin/gifts"><svg viewBox="0 0 24 24"><path d="M20 6h-2.18c.11-.31.18-.65.18-1 0-1.66-1.34-3-3-3-1.05 0-1.96.54-2.5 1.35l-.5.67-.5-.68C10.96 2.54 10.05 2 9 2 7.34 2 6 3.34 6 5c0 .35.07.69.18 1H4c-1.11 0-1.99.89-1.99 2L2 19c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V8c0-1.11-.89-2-2-2zm-5-2c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zM9 4c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm11 15H4v-2h16v2zm0-5H4V8h5.08L7 10.83 8.62 12 11 8.76l1-1.36 1 1.36L15.38 12 17 10.83 14.92 8H20v6z"/></svg>الهدايا</a></li>
                <div class="sidebar-divider"></div>
                <li><a href="/admin/users"><svg viewBox="0 0 24 24"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/></svg>المسوقين</a></li>
                <li><a href="/admin/withdrawals"><svg viewBox="0 0 24 24"><path d="M21 18v1c0 1.1-.9 2-2 2H5c-1.11 0-2-.9-2-2V5c0-1.1.89-2 2-2h14c1.1 0 2 .9 2 2v1h-9c-1.11 0-2 .9-2 2v8c0 1.1.89 2 2 2h9zm-9-2h10V8H12v8zm4-2.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/></svg>طلبات السحب</a></li>
                <div class="sidebar-divider"></div>
                <li><a href="/admin/settings/bank"><svg viewBox="0 0 24 24"><path d="M4 10v7h3v-7H4zm6 0v7h3v-7h-3zM2 22h19v-3H2v3zm14-12v7h3v-7h-3zm-4.5-9L2 6v2h19V6l-9.5-5z"/></svg>التحويل البنكي</a></li>
                <li><a href="/admin/settings"><svg viewBox="0 0 24 24"><path d="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.07.62-.07.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"/></svg>الاعدادات</a></li>
            </ul>
            <div class="sidebar-footer">
                <a href="/admin/logout">
                    <svg viewBox="0 0 24 24"><path d="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z"/></svg>
                    تسجيل الخروج
                </a>
            </div>
        </aside>

        <main class="main-content">
            <div class="page-title">
                <a href="/admin/pages">&larr; العودة للصفحات</a>
                <span><%= page ? 'تعديل الصفحة' : 'إنشاء صفحة جديدة' %></span>
            </div>

            <form method="POST" action="<%= page ? '/admin/pages/' + page.id + '/update' : '/admin/pages' %>">

                <!-- Basic Info -->
                <div class="section">
                    <h3>معلومات الصفحة</h3>
                    <div class="form-row">
                        <div class="form-group">
                            <label>العنوان بالعربية *</label>
                            <input type="text" name="title_ar" class="form-control" value="<%= page ? page.title_ar : '' %>" required id="titleAr">
                        </div>
                        <div class="form-group">
                            <label>العنوان بالفرنسية</label>
                            <input type="text" name="title_fr" class="form-control form-control-ltr" value="<%= page ? page.title_fr : '' %>" id="titleFr">
                        </div>
                    </div>
                    <div class="form-row-3">
                        <div class="form-group">
                            <label>الرابط (Slug) <small>يُولّد تلقائياً</small></label>
                            <input type="text" name="slug" class="form-control form-control-ltr" value="<%= page ? page.slug : '' %>" id="slugField" placeholder="auto-generated">
                            <div class="slug-preview" id="slugPreview"><%= page ? '/pages/' + page.slug : '' %></div>
                        </div>
                        <div class="form-group">
                            <label>الترتيب</label>
                            <input type="number" name="sort_order" class="form-control" value="<%= page ? page.sort_order : 0 %>" min="0">
                        </div>
                        <div class="form-group" style="display:flex;align-items:flex-end;padding-bottom:8px;">
                            <div class="checkbox-group">
                                <input type="checkbox" name="is_published" value="1" id="isPublished" <%= (!page || page.is_published) ? 'checked' : '' %>>
                                <label for="isPublished" style="margin:0;">منشور</label>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Content Tabs -->
                <div class="section">
                    <h3>المحتوى</h3>
                    <div class="tab-nav">
                        <button type="button" class="tab-btn active" onclick="switchTab('ar')">العربية</button>
                        <button type="button" class="tab-btn" onclick="switchTab('fr')">Français</button>
                    </div>
                    <div class="tab-content active" id="tab-ar">
                        <div class="form-group">
                            <div id="editor_ar"></div>
                            <input type="hidden" name="content_ar" id="content_ar_hidden">
                        </div>
                    </div>
                    <div class="tab-content" id="tab-fr" dir="ltr" style="direction: ltr; text-align: left;">
                        <div class="form-group">
                            <div id="editor_fr"></div>
                            <input type="hidden" name="content_fr" id="content_fr_hidden">
                        </div>
                    </div>
                </div>

                <!-- SEO -->
                <div class="section">
                    <h3>SEO (تحسين محركات البحث)</h3>
                    <div class="form-row">
                        <div class="form-group">
                            <label>عنوان SEO بالعربية</label>
                            <input type="text" name="meta_title_ar" class="form-control" value="<%= page ? page.meta_title_ar : '' %>">
                        </div>
                        <div class="form-group">
                            <label>عنوان SEO بالفرنسية</label>
                            <input type="text" name="meta_title_fr" class="form-control form-control-ltr" value="<%= page ? page.meta_title_fr : '' %>">
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label>وصف SEO بالعربية</label>
                            <textarea name="meta_description_ar" class="form-control" rows="3"><%= page ? page.meta_description_ar : '' %></textarea>
                        </div>
                        <div class="form-group">
                            <label>وصف SEO بالفرنسية</label>
                            <textarea name="meta_description_fr" class="form-control form-control-ltr" rows="3"><%= page ? page.meta_description_fr : '' %></textarea>
                        </div>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary"><%= page ? 'حفظ التعديلات' : 'إنشاء الصفحة' %></button>
                    <a href="/admin/pages" class="btn btn-outline">إلغاء</a>
                </div>
            </form>
        </main>
    </div>

    <script>
    // Tab switching
    function switchTab(lang) {
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
        event.target.classList.add('active');
        document.getElementById('tab-' + lang).classList.add('active');
    }

    // Auto-generate slug from Arabic title
    var titleAr = document.getElementById('titleAr');
    var titleFr = document.getElementById('titleFr');
    var slugField = document.getElementById('slugField');
    var slugPreview = document.getElementById('slugPreview');
    var isEdit = <%= page ? 'true' : 'false' %>;

    function generateSlug(text) {
        return text.toLowerCase()
            .replace(/[\u0600-\u06FF]/g, function(c) {
                // Transliterate common Arabic letters
                var map = {
                    'ا':'a','أ':'a','إ':'a','آ':'a','ب':'b','ت':'t','ث':'th','ج':'j','ح':'h','خ':'kh',
                    'د':'d','ذ':'dh','ر':'r','ز':'z','س':'s','ش':'sh','ص':'s','ض':'d','ط':'t','ظ':'z',
                    'ع':'a','غ':'gh','ف':'f','ق':'q','ك':'k','ل':'l','م':'m','ن':'n','ه':'h','و':'w',
                    'ي':'y','ى':'a','ة':'a','ئ':'e','ؤ':'o'
                };
                return map[c] || '';
            })
            .replace(/[^\w\s-]/g, '')
            .replace(/[\s_]+/g, '-')
            .replace(/^-+|-+$/g, '')
            || 'page';
    }

    function updateSlugPreview() {
        var s = slugField.value || generateSlug(titleAr.value || titleFr.value || '');
        slugPreview.textContent = s ? '/pages/' + s : '';
    }

    if (!isEdit) {
        titleAr.addEventListener('input', function() {
            if (!slugField.dataset.manual) {
                slugField.value = generateSlug(this.value || titleFr.value || '');
                updateSlugPreview();
            }
        });
        titleFr.addEventListener('input', function() {
            if (!slugField.dataset.manual && !titleAr.value) {
                slugField.value = generateSlug(this.value || '');
                updateSlugPreview();
            }
        });
    }
    slugField.addEventListener('input', function() {
        this.dataset.manual = this.value ? '1' : '';
        updateSlugPreview();
    });

    // Quill editor toolbar options
    var toolbarOptions = [
        [{ 'header': [1, 2, 3, 4, false] }],
        ['bold', 'italic', 'underline', 'strike'],
        [{ 'color': [] }, { 'background': [] }],
        [{ 'align': [] }],
        [{ 'list': 'ordered'}, { 'list': 'bullet' }],
        [{ 'direction': 'rtl' }],
        ['link', 'image', 'video'],
        ['blockquote', 'code-block'],
        ['clean']
    ];

    // Arabic editor (RTL)
    var quillAr = new Quill('#editor_ar', {
        theme: 'snow',
        modules: { toolbar: toolbarOptions },
        placeholder: 'اكتب المحتوى بالعربية...'
    });

    // French editor (LTR)
    var quillFr = new Quill('#editor_fr', {
        theme: 'snow',
        modules: { toolbar: toolbarOptions },
        placeholder: 'Écrivez le contenu en français...'
    });
    // Set French editor to LTR
    document.querySelector('#editor_fr .ql-editor').classList.add('ltr');
    document.querySelector('#editor_fr .ql-editor').style.direction = 'ltr';
    document.querySelector('#editor_fr .ql-editor').style.textAlign = 'left';
    // Also set toolbar LTR for French editor
    var frToolbar = document.querySelector('#tab-fr .ql-toolbar');
    if (frToolbar) { frToolbar.style.direction = 'ltr'; frToolbar.style.textAlign = 'left'; }

    // Load existing content
    <% if (page && page.content_ar) { %>
    quillAr.root.innerHTML = <%- JSON.stringify(page.content_ar) %>;
    <% } %>
    <% if (page && page.content_fr) { %>
    quillFr.root.innerHTML = <%- JSON.stringify(page.content_fr) %>;
    <% } %>

    // Before form submit, copy Quill HTML to hidden inputs
    document.querySelector('form').addEventListener('submit', function() {
        document.getElementById('content_ar_hidden').value = quillAr.root.innerHTML === '<p><br></p>' ? '' : quillAr.root.innerHTML;
        document.getElementById('content_fr_hidden').value = quillFr.root.innerHTML === '<p><br></p>' ? '' : quillFr.root.innerHTML;
    });
    </script>
</body>
</html>
