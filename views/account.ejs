<!DOCTYPE html>
<html lang="<%= typeof lang !== 'undefined' ? lang : 'ar' %>" dir="<%= typeof dir !== 'undefined' ? dir : 'rtl' %>">
<head>
  <%- include('partials/head') %>
  <title>حسابي — <%= typeof siteName !== 'undefined' ? siteName : 'متجرنا' %></title>
</head>
<body>
  <div class="pattern-overlay"></div>

  <!-- Navbar -->
  <nav class="navbar scrolled">
    <div class="container">
      <div class="navbar__inner">
        <div class="navbar__brand">
          <a href="/" style="display: flex; align-items: center; gap: 10px;">
            <% if (typeof desktopLogo !== 'undefined' && desktopLogo) { %>
              <img src="/uploads/settings/<%= desktopLogo %>" alt="" style="height: 36px; width: auto;">
            <% } else { %>
              <div class="navbar__logo"><%= typeof siteName !== 'undefined' ? siteName.charAt(0) : 'م' %></div>
              <span class="navbar__name"><%= typeof siteName !== 'undefined' ? siteName : 'متجرنا' %></span>
            <% } %>
          </a>
        </div>
        <div style="display: flex; align-items: center; gap: 12px;">
          <a href="/account/orders" style="color: var(--color-text); font-size: 14px; text-decoration: none;">طلباتي</a>
          <a href="/account/settings" style="color: var(--color-text); font-size: 14px; text-decoration: none;">الإعدادات</a>
          <a href="/logout" class="navbar__cta" style="font-size: 13px; padding: 8px 16px; background: var(--color-error);">تسجيل الخروج</a>
        </div>
      </div>
    </div>
  </nav>

  <!-- Account Dashboard -->
  <section class="hero" style="padding-bottom: 80px;">
    <div class="container" style="max-width: 900px;">
      <div class="section-header" style="margin-top: 20px;">
        <span class="section-header__label">مرحبا، <%= user.full_name %></span>
        <h1 class="section-header__title">لوحة التحكم</h1>
        <div class="section-header__divider"></div>
      </div>

      <!-- Stats Grid -->
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 16px; margin-bottom: 30px;">
        <!-- Total Orders -->
        <div class="feature-card" style="padding: 24px; text-align: center;">
          <div style="font-size: 36px; margin-bottom: 8px;">📦</div>
          <div style="font-size: 28px; font-weight: 800; color: var(--color-primary);"><%= user.total_orders %></div>
          <div style="font-size: 13px; color: var(--color-text-secondary); font-weight: 600;">إجمالي الطلبات</div>
        </div>

        <!-- Total Earned -->
        <div class="feature-card" style="padding: 24px; text-align: center;">
          <div style="font-size: 36px; margin-bottom: 8px;">💰</div>
          <div style="font-size: 28px; font-weight: 800; color: var(--color-primary);"><%= user.total_earned.toFixed(2) %></div>
          <div style="font-size: 13px; color: var(--color-text-secondary); font-weight: 600;">إجمالي الأرباح (درهم)</div>
        </div>

        <!-- Available Balance -->
        <div class="feature-card" style="padding: 24px; text-align: center;">
          <div style="font-size: 36px; margin-bottom: 8px;">💵</div>
          <div style="font-size: 28px; font-weight: 800; color: var(--color-success);"><%= user.available_balance.toFixed(2) %></div>
          <div style="font-size: 13px; color: var(--color-text-secondary); font-weight: 600;">الرصيد المتاح (درهم)</div>
        </div>

        <!-- Total Withdrawn -->
        <div class="feature-card" style="padding: 24px; text-align: center;">
          <div style="font-size: 36px; margin-bottom: 8px;">🏧</div>
          <div style="font-size: 28px; font-weight: 800; color: var(--color-text-muted);"><%= user.total_withdrawn.toFixed(2) %></div>
          <div style="font-size: 13px; color: var(--color-text-secondary); font-weight: 600;">إجمالي السحب (درهم)</div>
        </div>
      </div>

      <!-- Referral Link -->
      <div class="feature-card" style="padding: 24px; margin-bottom: 24px;">
        <h3 style="font-size: 18px; font-weight: 700; color: var(--color-primary-dark); margin-bottom: 12px;">🔗 رابط الإحالة الخاص بك</h3>
        <p style="font-size: 13px; color: var(--color-text-secondary); margin-bottom: 12px;">
          شارك هذا الرابط مع أصدقائك. عند كل عملية شراء عبر رابطك، ستحصل على عمولة <strong><%= user.commission_rate %>%</strong>.
        </p>
        <div style="display: flex; gap: 8px; align-items: center;">
          <input type="text" id="referralLink" class="form-input" readonly
            value="<%= typeof siteUrl !== 'undefined' ? siteUrl : '' %>/<%= user.referral_code %>"
            style="flex: 1; font-size: 14px; direction: ltr; text-align: left; background: var(--color-bg);">
          <button type="button" class="btn btn--primary" onclick="copyReferralLink()" style="white-space: nowrap; padding: 10px 20px;">
            نسخ الرابط
          </button>
        </div>
      </div>

      <!-- Withdrawal Section -->
      <div class="feature-card" style="padding: 24px; margin-bottom: 24px;">
        <h3 style="font-size: 18px; font-weight: 700; color: var(--color-primary-dark); margin-bottom: 12px;">🏧 طلب سحب</h3>
        <% if (user.available_balance <= 0) { %>
          <p style="color: var(--color-text-muted); font-size: 14px;">لا يوجد رصيد متاح للسحب حالياً.</p>
        <% } else if (typeof minOrders !== 'undefined' && user.total_orders < minOrders) { %>
          <p style="color: var(--color-error); font-size: 14px;">يجب أن يكون لديك على الأقل <%= minOrders %> طلب للسحب. لديك حالياً <%= user.total_orders %> طلب.</p>
        <% } else { %>
          <form id="withdrawForm" novalidate>
            <div class="form-group" style="margin-bottom: 12px;">
              <label class="form-label">المبلغ (درهم)</label>
              <input type="number" id="withdrawAmount" class="form-input" placeholder="أدخل المبلغ" min="10" max="<%= user.available_balance %>" step="0.01" required>
              <div class="form-error"></div>
            </div>
            <div class="form-group" style="margin-bottom: 12px;">
              <label class="form-label">اسم البنك</label>
              <input type="text" id="withdrawBankName" class="form-input" placeholder="مثل: CIH, Attijariwafa..." required>
              <div class="form-error"></div>
            </div>
            <div class="form-group" style="margin-bottom: 12px;">
              <label class="form-label">صاحب الحساب</label>
              <input type="text" id="withdrawHolder" class="form-input" placeholder="الاسم الكامل لصاحب الحساب" required>
              <div class="form-error"></div>
            </div>
            <div class="form-group" style="margin-bottom: 16px;">
              <label class="form-label">RIB</label>
              <input type="text" id="withdrawRib" class="form-input" placeholder="رقم الحساب البنكي" required dir="ltr" style="text-align: left;">
              <div class="form-error"></div>
            </div>
            <button type="submit" class="btn btn--primary" id="withdrawBtn">إرسال طلب السحب</button>
          </form>
        <% } %>
      </div>

      <!-- Recent Commissions -->
      <div class="feature-card" style="padding: 24px;">
        <h3 style="font-size: 18px; font-weight: 700; color: var(--color-primary-dark); margin-bottom: 16px;">📊 آخر العمولات</h3>
        <% if (typeof commissions !== 'undefined' && commissions && commissions.length > 0) { %>
          <div style="overflow-x: auto;">
            <table style="width: 100%; border-collapse: collapse; font-size: 14px;">
              <thead>
                <tr style="background: var(--color-bg-warm);">
                  <th style="padding: 10px 12px; text-align: right; font-weight: 700; border-bottom: 2px solid var(--color-border);">التاريخ</th>
                  <th style="padding: 10px 12px; text-align: right; font-weight: 700; border-bottom: 2px solid var(--color-border);">مبلغ الطلب</th>
                  <th style="padding: 10px 12px; text-align: right; font-weight: 700; border-bottom: 2px solid var(--color-border);">النسبة</th>
                  <th style="padding: 10px 12px; text-align: right; font-weight: 700; border-bottom: 2px solid var(--color-border);">العمولة</th>
                  <th style="padding: 10px 12px; text-align: right; font-weight: 700; border-bottom: 2px solid var(--color-border);">الحالة</th>
                </tr>
              </thead>
              <tbody>
                <% commissions.forEach(function(c) { %>
                <tr>
                  <td style="padding: 10px 12px; border-bottom: 1px solid var(--color-border-light);"><%= c.created_at ? c.created_at.substring(0, 10) : '-' %></td>
                  <td style="padding: 10px 12px; border-bottom: 1px solid var(--color-border-light);"><%= c.order_amount %> د.م</td>
                  <td style="padding: 10px 12px; border-bottom: 1px solid var(--color-border-light);"><%= c.commission_rate %>%</td>
                  <td style="padding: 10px 12px; border-bottom: 1px solid var(--color-border-light); font-weight: 700; color: var(--color-success);"><%= c.commission_amount.toFixed(2) %> د.م</td>
                  <td style="padding: 10px 12px; border-bottom: 1px solid var(--color-border-light);">
                    <span style="padding: 3px 10px; border-radius: 50px; font-size: 11px; font-weight: 700;
                      background: <%= c.status === 'confirmed' ? 'var(--color-success-light)' : 'var(--color-bg-warm)' %>;
                      color: <%= c.status === 'confirmed' ? 'var(--color-success)' : 'var(--color-text-muted)' %>;
                    "><%= c.status === 'confirmed' ? 'مؤكد' : 'معلق' %></span>
                  </td>
                </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <p style="color: var(--color-text-muted); font-size: 14px; text-align: center; padding: 20px;">لا توجد عمولات بعد. شارك رابط الإحالة لبدء الربح!</p>
        <% } %>
      </div>
    </div>
  </section>

  <%- include('partials/footer') %>

  <script>
    function copyReferralLink() {
      var input = document.getElementById('referralLink');
      if (!input) return;
      navigator.clipboard.writeText(input.value).then(function() {
        showToast('تم نسخ الرابط بنجاح', 'success');
      }).catch(function() {
        input.select();
        document.execCommand('copy');
        showToast('تم نسخ الرابط', 'success');
      });
    }

    // Withdrawal form
    document.addEventListener('DOMContentLoaded', function() {
      var form = document.getElementById('withdrawForm');
      if (!form) return;

      form.addEventListener('submit', function(e) {
        e.preventDefault();

        var amount = document.getElementById('withdrawAmount');
        var bankName = document.getElementById('withdrawBankName');
        var holder = document.getElementById('withdrawHolder');
        var rib = document.getElementById('withdrawRib');
        var btn = document.getElementById('withdrawBtn');

        if (!amount.value || parseFloat(amount.value) <= 0) {
          showToast('يرجى إدخال مبلغ صحيح', 'error');
          return;
        }
        if (!bankName.value.trim() || !holder.value.trim() || !rib.value.trim()) {
          showToast('يرجى تعبئة جميع الحقول', 'error');
          return;
        }

        btn.disabled = true;
        btn.textContent = 'جاري الإرسال...';

        fetch('/account/withdraw', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            amount: parseFloat(amount.value),
            bank_name: bankName.value.trim(),
            holder_name: holder.value.trim(),
            rib: rib.value.trim()
          })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.success) {
            showToast('تم إرسال طلب السحب بنجاح', 'success');
            setTimeout(function() { window.location.reload(); }, 1500);
          } else {
            showToast(data.error || 'حدث خطأ', 'error');
            btn.disabled = false;
            btn.textContent = 'إرسال طلب السحب';
          }
        })
        .catch(function() {
          showToast('حدث خطأ في الاتصال', 'error');
          btn.disabled = false;
          btn.textContent = 'إرسال طلب السحب';
        });
      });
    });
  </script>
  <script src="/js/main.js"></script>
</body>
</html>
